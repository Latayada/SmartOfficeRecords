@{
    ViewBag.Title = "Add New User";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Add New User</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: #f4f6f9;
            overflow: hidden;
        }
        /* ==========================
                DASHBOARD DESIGN
           ===========================*/

        .dashboard-container {
            display: flex;
            height: 100vh;
        }

        /* ==========================
                  SIDEBAR DESIGN
           ===========================*/

        .sidebar {
            width: 190px;
            background: #0b1f3a;
            color: white;
            display: flex;
            flex-direction: column;
            transition: all .3s ease;
        }

            /* ==========================
                     COLLAPSED SIDEBAR
               ===========================*/
            .sidebar.collapsed {
                width: 90px;
            }

                /* Keep SORS visible */
                .sidebar.collapsed .system-name {
                    display: block;
                    font-size: 12px;
                    font-weight: 600;
                    margin-top: 10px;
                }

                /* Logo size when collapsed */
                .sidebar.collapsed .logo-circle {
                    width: 58px;
                    height: 58px;
                }

                /* Keep divider line */
                .sidebar.collapsed .logo-section {
                    padding: 25px 15px;
                    border-bottom: 1px solid rgba(255,255,255,.15);
                }

                /* Hide menu text only */
                .sidebar.collapsed .menu a span,
                .sidebar.collapsed .logout a span {
                    display: none;
                }

                /* Menu layout */
                .sidebar.collapsed .menu {
                    padding: 20px 12px;
                }

                    /* Menu items */
                    .sidebar.collapsed .menu a {
                        width: 50px;
                        height: 50px;
                        margin: 0 auto 18px auto;
                        padding: 0;
                        display: flex;
                        justify-content: center;
                        align-items: center;
                        border-radius: 8px;
                    }

                        /* Active menu */
                        .sidebar.collapsed .menu a.active {
                            background: #1e4f8a;
                            box-shadow: 0 4px 10px rgba(0,0,0,.15);
                        }

                        /* Keep icon size same as expanded */
                        .sidebar.collapsed .menu a i,
                        .sidebar.collapsed .logout a i {
                            margin: 0;
                            font-size: inherit;
                        }

                /* Logout */
                .sidebar.collapsed .logout {
                    margin-top: auto;
                    padding-bottom: 20px;
                }

                    .sidebar.collapsed .logout a {
                        width: 50px;
                        height: 50px;
                        margin: 0 auto;
                        padding: 0;
                        display: flex;
                        justify-content: center;
                        align-items: center;
                    }

        /* ================
                       SETTINGS DROPDOWN
                   ====================== */

        .sidebar-dropdown {
            margin-bottom: 10px;
        }

        .dropdown-toggle-menu {
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 6px;
            cursor: pointer;
        }

            .dropdown-toggle-menu:hover {
                background: rgba(255,255,255,.12);
            }

        .small-arrow {
            font-size: 12px;
            transition: transform .3s ease;
        }

        /* submenu */
        .dropdown-submenu {
            display: none;
            flex-direction: column;
            padding-left: 20px;
        }

            .dropdown-submenu a {
                color: white;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 10px 12px;
                font-size: 14px;
                border-radius: 6px;
            }

                .dropdown-submenu a:hover {
                    background: rgba(255,255,255,.12);
                }

        /* active state */
        .sidebar-dropdown.open .dropdown-submenu {
            display: flex;
        }

        .sidebar-dropdown.open .small-arrow {
            transform: rotate(180deg);
        }

        /* Hide dropdown arrow when sidebar is collapsed */
        .sidebar.collapsed .small-arrow {
            display: none;
        }

        /* ==========================
                 LOGO DESIGN
           ===========================*/
        .logo-section {
            text-align: center;
            padding: 25px 15px;
            border-bottom: 1px solid rgba(255, 255, 255, .15);
        }

        .logo-circle {
            width: 60px;
            height: 60px;
            background: white;
            border-radius: 50%;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .logout {
            margin-top: auto;
            padding: 15px 12px;
        }

            .logout a {
                color: white;
                text-decoration: none;
                display: flex;
                gap: 12px;
                align-items: center;
                padding: 12px 14px;
            }

        .system-name {
            margin-top: 12px;
            font-size: 14px;
            font-weight: 600;
        }
        /* ==========================
                  MENU DESIGN
           ===========================*/

        .menu {
            padding: 20px 12px;
        }

            .menu a {
                color: white;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 14px;
                margin-bottom: 10px;
                border-radius: 6px;
            }

                .menu a:hover {
                    background: rgba(255,255,255,.12);
                }

                .menu a.active {
                    background: #1e4f8a;
                    box-shadow: 0 4px 10px rgba(0,0,0,.15);
                }

        /* ==========================
                   MAIN CONTENT
           ===========================*/

        .main-content {
            flex: 1;
            background: #f4f6f9;
        }

        /* ==========================
                     TOP BAR
          ===========================*/
        .topbar {
            height: 60px;
            border-bottom: 1px solid #d9dce3;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
            background: #fff;
        }

        .menu-toggle {
            background: none;
            border: none;
            color: #0b1f3a;
            font-size: 22px;
            cursor: pointer;
            margin-right: 10px;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 18px;
            margin-right: 8px;
        }

            .topbar-left i {
                font-size: 28px;
                color: #0b1f3a;
                cursor: pointer;
                margin: 8px;
            }

            .topbar-left h3 {
                color: #0b1f3a;
                font-weight: 700;
                margin: 0;
            }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-left: auto;
        }

            .topbar-right i {
                font-size: 24px;
                cursor: pointer;
            }

        .profile {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .profile img {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                object-fit: cover;
            }

        .profile-info {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

            .profile-info .role {
                font-size: 12px;
                color: #777;
            }

            .profile-info h5 {
                margin: 0;
                font-size: 14px;
                font-weight: 600;
                color: #1e4f8a;
            }

            .profile-info span {
                font-size: 12px;
                color: gray;
            }

        /* CONTENT */
        .content-area {
            padding: 30px;
            overflow:hidden;
        }
        .page-container {
            padding: 35px;
        }

        /*breadcrumb*/
        .breadcrumb-title {
            font-size: 20px;
            font-weight: 700;
            margin-bottom: 25px;
        }

            .breadcrumb-title span {
                color: #9ca3af;
            }

            .breadcrumb-title strong {
                color: #1e4f8a;
            }

        .users-breadcrumb {
            text-decoration: none;
            color: #9ca3af;
            transition: 0.3s ease;
        }

            .users-breadcrumb:hover {
                color: #1e4f8a;
            }

        .form-wrapper {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
        }

        .form-group {
            margin-bottom: 15px;
        }

        label {
            font-weight: 600;
            margin-bottom: 8px;
            display: block;
        }

        .input-group-text {
            background: #f8fafc;
            border-right: none;
            color: #000000;
            width: 48px;
            justify-content: center;
        }

        .form-control {
            border-left: none;
            height: 48px;
        }

        .role-container {
            display: flex;
            gap: 15px;
        }

        .role-card {
            flex: 1;
            border: 2px solid #dbe3ff;
            border-radius: 10px;
            padding: 18px;
            text-align: center;
            cursor: pointer;
            transition: .3s;
        }

            .role-card:hover {
                transform: translateY(0px);
                box-shadow: 0 3px 8px rgba(11, 31, 58, 0.25);
            }

            .role-card.active {
                border-color: #1e4f8a;
                background: #f4f8ff;
            }

        .admin-role i {
            color: #2563eb;
        }

        .staff-role i {
            color: #16a34a;
        }

        .admin-role.active {
            border-color: #dbe3ff;
            background: #eff6ff;
        }

        .staff-role.active {
            border-color: #16a34a;
            background: #f0fdf4;
        }

        .button-area {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 15px;
            margin-top: 25px;
            width: 100%;
        }

        .btn-cancel {
            background: #ececec;
            border: none;
            width: 140px;
            height: 50px;
            border-radius: 8px;
            font-weight: 600;
        }

        .btn-save {
            background: #1e4f8a;
            color: white;
            border: none;
            width: 160px;
            height: 50px;
            border-radius: 8px;
            font-weight: 600;
        }

    </style>
</head>
<body>

    <div class="dashboard-container">

        <!-- SIDEBAR -->
        <aside class="sidebar">

            <div class="logo-section">

                <div class="logo-circle">
                    <img src="~/Images/logo.png" class="logo-img">
                </div>

                <div class="system-name">
                    SORS
                </div>

            </div>

            <div class="menu">

                <a href="@Url.Action("Dashboard", "Admin")">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>

                <a href="@Url.Action("RequestManagement", "Admin")">
                    <i class="bi bi-file-earmark-text"></i>
                    <span>Request</span>
                </a>

                <a href="@Url.Action("RecordsManagement", "Admin")">
                    <i class="bi bi-folder2-open"></i>
                    <span>Records</span>
                </a>

                <a href="@Url.Action("ReportsManagement", "Admin")">
                    <i class="bi bi-clipboard-data"></i>
                    <span>Reports</span>
                </a>

                <!-- ACTIVE PAGE -->
                <a href="@Url.Action("UsersManagement", "Admin")" class="active">
                    <i class="bi bi-people"></i>
                    <span>Users</span>
                </a>

                <!-- SETTINGS DROPDOWN -->
                <div class="sidebar-dropdown">

                    <a href="javascript:void(0)" class="dropdown-toggle-menu">
                        <i class="bi bi-gear"></i>
                        <span>Settings</span>
                        <i class="bi bi-caret-down-fill ms-auto small-arrow"></i>
                    </a>

                    <div class="dropdown-submenu">

                        <a href="@Url.Action("Settings", "Admin")">
                            <i class="bi bi-sliders"></i>
                            <span>General Settings</span>
                        </a>

                        <a href="#">
                            <i class="bi bi-person-gear"></i>
                            <span>Account & Security</span>
                        </a>

                    </div>
                </div>

            </div>

            <div class="logout">
                <a href="@Url.Action("Login", "Admin")">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Logout</span>
                </a>
            </div>

        </aside>

        <!-- MAIN CONTENT -->
        <div class="main-content">

            <!-- TOPBAR -->
            <div class="topbar">

                <div class="topbar-left">

                    <button class="menu-toggle" id="menuToggle">
                        <i class="bi bi-list"></i>
                    </button>

                </div>

                <div class="topbar-right">

                    <i class="bi bi-bell-fill"></i>

                    <div class="profile">

                        <img src="~/Images/adminpic.jpg" alt="Profile" />

                        <div class="profile-info">
                            <span class="role">Administrator</span>
                            <h5>Juan Dela Cruz</h5>
                        </div>

                    </div>

                </div>

            </div>

            <!-- PAGE CONTENT -->
            <div class="content-area">

                <div class="breadcrumb-title">

                    <a href="@Url.Action("UsersManagement", "Admin")"
                       class="users-breadcrumb">

                        Users

                    </a>

                    ›

                    <strong>Add New user</strong>

                </div>

                <form>

                    <div class="form-wrapper">

                        <!-- LEFT COLUMN -->
                        <div>

                            <div class="form-group">
                                <label>Full Name</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-person-fill"></i>
                                    </span>
                                    <input type="text"
                                           class="form-control"
                                           placeholder="Enter full name">
                                </div>
                            </div>

                            <div class="form-group">
                                <label>Contact Number</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-telephone-fill"></i>
                                    </span>
                                    <input type="text"
                                           class="form-control"
                                           placeholder="Enter contact number">
                                </div>
                            </div>

                            <div class="form-group">
                                <label>Username</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-person-badge-fill"></i>
                                    </span>
                                    <input type="text"
                                           class="form-control"
                                           placeholder="Enter username">
                                </div>
                            </div>

                            <div class="form-group">
                                <label>Password</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-lock-fill"></i>
                                    </span>
                                    <input type="password"
                                           class="form-control"
                                           placeholder="Enter password">
                                </div>
                            </div>

                            <div class="form-group">
                                <label>Confirm Password</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-shield-fill-check"></i>
                                    </span>
                                    <input type="password"
                                           class="form-control"
                                           placeholder="Confirm Password">
                                </div>
                            </div>

                        </div>

                        <!-- RIGHT COLUMN -->
                        <div>

                            <div class="form-group">
                                <label>Email Address</label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="bi bi-envelope-fill"></i>
                                    </span>
                                    <input type="email"
                                           class="form-control"
                                           placeholder="Enter email address">
                                </div>
                            </div>

                            <div class="form-group">

                                <label>Role</label>

                                <div class="role-container">

                                    <div class="role-card admin-role">
                                        <i class="bi bi-shield-lock-fill"></i>
                                        <h5>Admin</h5>
                                    </div>

                                    <div class="role-card staff-role">
                                        <i class="bi bi-person-workspace"></i>
                                        <h5>Staff</h5>
                                    </div>

                                </div>

                            </div>

                        </div>

                    </div>

                    <div class="button-area">

                        <button type="button"
                                class="btn-cancel"
                                onclick="window.location.href='@Url.Action("UsersManagement", "Admin")'">
                            Cancel
                        </button>

                        <button type="submit"
                                class="btn-save">

                            <i class="bi bi-floppy"></i>
                            Save User

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

    <script>

        const dropdown = document.querySelector('.sidebar-dropdown');
             const toggle = document.querySelector('.dropdown-toggle-menu');

         toggle.addEventListener('click', function () {
             dropdown.classList.toggle('open');
         });

         const sidebar = document.querySelector('.sidebar');
         const toggleBtn = document.getElementById('menuToggle');

         toggleBtn.addEventListener('click', function () {
             sidebar.classList.toggle('collapsed');
         });
    </script>

</body>
</html>