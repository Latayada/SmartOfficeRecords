@{
    ViewBag.Title = "Request Management";
    Layout = null;
}

<!DOCTYPE html>
<html>
    <head>

        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <title>Request Management</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

        <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Poppins', sans-serif;
            }

            body {
                background: #f4f6f9;
                overflow: hidden;
            }

        /* ==========================
                DASHBOARD DESIGN
           ===========================*/

        .dashboard-container {
            display: flex;
            height: 100vh;
        }

        /* ==========================
                        IDEBAR DESIGN
                  ===========================*/

        .sidebar {
            width: 190px;
            background: #0b1f3a;
            color: white;
            display: flex;
            flex-direction: column;
            transition: all .3s ease;
        }

            /* ==========================
                    COLLAPSED SIDEBAR
               ===========================*/
            .sidebar.collapsed {
                width: 90px;
            }

                /* Keep SORS visible */
                .sidebar.collapsed .system-name {
                    display: block;
                    font-size: 12px;
                    font-weight: 600;
                    margin-top: 10px;
                }

                /* Logo size when collapsed */
                .sidebar.collapsed .logo-circle {
                    width: 58px;
                    height: 58px;
                }

                /* Keep divider line */
                .sidebar.collapsed .logo-section {
                    padding: 25px 15px;
                    border-bottom: 1px solid rgba(255,255,255,.15);
                }

                /* Hide menu text only */
                .sidebar.collapsed .menu a span,
                .sidebar.collapsed .logout a span {
                    display: none;
                }

                /* Menu layout */
                .sidebar.collapsed .menu {
                    padding: 20px 12px;
                }

                    /* Menu items */
                    .sidebar.collapsed .menu a {
                        width: 50px;
                        height: 50px;
                        margin: 0 auto 18px auto;
                        padding: 0;
                        display: flex;
                        justify-content: center;
                        align-items: center;
                        border-radius: 8px;
                    }

                        /* Active menu */
                        .sidebar.collapsed .menu a.active {
                            background: #1e4f8a;
                            box-shadow: 0 4px 10px rgba(0,0,0,.15);
                        }

                        /* Keep icon size same as expanded */
                        .sidebar.collapsed .menu a i,
                        .sidebar.collapsed .logout a i {
                            margin: 0;
                            font-size: inherit;
                        }

                /* Logout */
                .sidebar.collapsed .logout {
                    margin-top: auto;
                    padding-bottom: 20px;
                }

                    .sidebar.collapsed .logout a {
                        width: 50px;
                        height: 50px;
                        margin: 0 auto;
                        padding: 0;
                        display: flex;
                        justify-content: center;
                        align-items: center;
                    }

        /* ================
              SETTINGS DROPDOWN
           ====================== */

        .sidebar-dropdown {
            margin-bottom: 10px;
        }

        .dropdown-toggle-menu {
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 6px;
            cursor: pointer;
        }

            .dropdown-toggle-menu:hover {
                background: rgba(255,255,255,.12);
            }

        .small-arrow {
            font-size: 12px;
            transition: transform .3s ease;
        }

        /* submenu */
        .dropdown-submenu {
            display: none;
            flex-direction: column;
            padding-left: 20px;
        }

            .dropdown-submenu a {
                color: white;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 10px 12px;
                font-size: 14px;
                border-radius: 6px;
            }

                .dropdown-submenu a:hover {
                    background: rgba(255,255,255,.12);
                }

        /* active state */
        .sidebar-dropdown.open .dropdown-submenu {
            display: flex;
        }

        .sidebar-dropdown.open .small-arrow {
            transform: rotate(180deg);
        }

        /* Hide dropdown arrow when sidebar is collapsed */
        .sidebar.collapsed .small-arrow {
            display: none;
        }

        /* ==========================
                 LOGO DESIGN
           ===========================*/
        .logo-section {
            text-align: center;
            padding: 25px 15px;
            border-bottom: 1px solid rgba(255, 255, 255, .15);
        }

        .logo-circle {
            width: 60px;
            height: 60px;
            background: white;
            border-radius: 50%;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .logout {
            margin-top: auto;
            padding: 15px 12px;
        }

            .logout a {
                color: white;
                text-decoration: none;
                display: flex;
                gap: 12px;
                align-items: center;
                padding: 12px 14px;
            }

        .system-name {
            margin-top: 12px;
            font-size: 14px;
            font-weight: 600;
        }
        /* ==========================
                  MENU DESIGN
           ===========================*/

        .menu {
            padding: 20px 12px;
        }

            .menu a {
                color: white;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 14px;
                margin-bottom: 10px;
                border-radius: 6px;
            }

                .menu a:hover {
                    transform: translateY(0px);
                    box-shadow: 0 3px 8px rgba(11, 31, 58, 0.25);
                }

                .menu a.active {
                    background: #1e4f8a;
                    box-shadow: 0 4px 10px rgba(0,0,0,.15);
                }

            /* MAIN CONTENT */
            .main-content {
                flex: 1;
                background: #f4f6f9;
            }

        /* ==========================
                   TOP BAR
           ===========================*/
        .topbar {
            height: 60px;
            border-bottom: 1px solid #d9dce3;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
            background: #fff;
        }

        .menu-toggle {
            background: none;
            border: none;
            color: #0b1f3a;
            font-size: 22px;
            cursor: pointer;
            margin-right: 10px;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 18px;
            margin-right: 8px;
        }

            .topbar-left i {
                font-size: 28px;
                color: #0b1f3a;
                cursor: pointer;
                margin: 8px;
            }

            .topbar-left h3 {
                color: #0b1f3a;
                font-weight: 700;
                margin: 0;
            }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-left: auto;
        }

            .topbar-right i {
                font-size: 24px;
                cursor: pointer;
            }

        .profile {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .profile img {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                object-fit: cover;
            }

        .profile-info {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

            .profile-info .role {
                font-size: 12px;
                color: #777;
            }

            .profile-info h5 {
                margin: 0;
                font-size: 14px;
                font-weight: 600;
                color: #1e4f8a;
            }

            .profile-info span {
                font-size: 12px;
                color: gray;
            }

            /* CONTENT */
            .content-area {
                padding: 30px;
            }

            .page-title {
                font-size: 20px;
                font-weight: 700;
                color: #1e4f8a;
                margin-bottom: 25px;
            }

            /* ACTION BAR */
            .action-bar {
                display: flex;
                justify-content: space-between;
                align-items: center;
                margin-bottom: 20px;
                gap: 15px;
                flex-wrap: wrap;
            }

            .search-filter {
                display: flex;
                gap: 15px;
                flex: 1;
            }

            .search-box {
                flex: 1;
                position: relative;
            }

                .search-box i {
                    position: absolute;
                    top: 14px;
                    left: 14px;
                    color: #9ca3af;
                    font-size: 16px;
                }

                .search-box input {
                    width: 100%;
                    height: 50px;
                    border: 1px solid #d1d5db;
                    border-radius: 8px;
                    padding-left: 42px;
                    font-size: 15px;
                    outline: none;
                }

            .status-filter {
                width: 220px;
                height: 50px;
                border: 1px solid #d1d5db;
                border-radius: 8px;
                padding: 0 15px;
                font-size: 15px;
                font-weight: 500;
                outline: none;
            }

            .create-btn {
                background: #1e4f8a;
                border: none;
                color: white;
                height: 50px;
                padding: 0 24px;
                border-radius: 8px;
                font-weight: 600;
                font-size: 15px;
                transition: 0.3s ease;
                display: flex;
                align-items: center;
                gap: 10px;
                text-decoration: none;
            }

                .create-btn:hover {
                    transform: translateY(0px);
                    box-shadow: 0 3px 8px rgba(11, 31, 58, 0.25);
                }

            /* TABLE */

            .table-container {
                background: white;
                border-radius: 10px;
                overflow: hidden;
                border: 1px solid #e5e7eb;
            }

            .table {
                margin-bottom: 0;
            }

                .table thead {
                    background: #f3f4f6;
                }

                    .table thead th {
                        padding: 18px;
                        font-size: 15px;
                        font-weight: 700;
                        color: #111827;
                        border-bottom: 1px solid #d1d5db;
                    }

                .table tbody td {
                    padding: 18px;
                    vertical-align: middle;
                    font-size: 14px;
                    color: #374151;
                    border-bottom: 1px solid #f1f1f1;
                }

            .action-icons {
                display: flex;
                gap: 18px;
                font-size: 18px;
            }

                .action-icons i {
                    cursor: pointer;
                    transition: 0.3s ease;
                }

                    .action-icons i:hover {
                        color: #3b82f6;
                    }

            /* PAGINATION */
            .pagination-section {
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 18px;
                margin-top: 35px;
            }

            .page-number {
                width: 34px;
                height: 34px;
                border-radius: 6px;
                display: flex;
                justify-content: center;
                align-items: center;
                font-weight: 600;
                cursor: pointer;
            }

            .active-page {
                background: #1e4f8a;
                color: white;
            }

        </style>

    </head>

    <body>

        <div class="dashboard-container">

            <!-- SIDEBAR -->
        <aside class="sidebar">

            <div class="logo-section">

                <div class="logo-circle">
                    <img src="~/Images/logo.png" class="logo-img">
                </div>

                <div class="system-name">
                    SORS
                </div>

            </div>

            <div class="menu">

                <a href="@Url.Action("Dashboard", "Admin")">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>

                <a href="@Url.Action("RequestManagement", "Admin")" class="active">
                    <i class="bi bi-file-earmark-text"></i>
                    <span>Request</span>
                </a>

                <a href="@Url.Action("RecordsManagement", "Admin")">
                    <i class="bi bi-folder2-open"></i>
