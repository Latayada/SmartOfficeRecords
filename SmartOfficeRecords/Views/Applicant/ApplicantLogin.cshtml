@{
    ViewBag.Title = "Applicant Login";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Applicant Login</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: #f3f4f6;
            min-height: 100vh;
            overflow: hidden;
        }

        .main-container {
            width: 100%;
            height: 100vh;
            display: flex;
        }

        .login-wrapper {
            width: 100%;
            height: 100vh;
            display: flex;
            overflow: hidden;
            background: white;
        }

        /* LEFT SIDE */
        .left-side {
            width: 40%;
            height: 100vh;
            background: #168a3b;
            position: relative;
        }

        .top-content {
            text-align: center;
            padding-top: 70px;
            position: relative;
            z-index: 2;
        }

            .top-content img {
                width: 130px;
                margin-bottom: 25px;
            }

            .top-content h1 {
                color: white;
                font-size: 44px;
                font-weight: 700;
                line-height: 1.3;
            }

        .bottom-image {
            position: absolute;
            bottom: 0;
            width: 100%;
        }

            .bottom-image img {
                width: 100%;
                height: 52vh;
                object-fit: cover;
            }

        /* RIGHT SIDE */
        .right-side {
            width: 60%;
            height: 100vh;
            background: #f8f8f8;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px;
        }

        /* LOGIN CARD */
        .login-card {
            width: 100%;
            max-width: 470px;
            background: white;
            border: 1px solid #dddddd;
            border-radius: 8px;
            padding: 50px;
        }

            .login-card h2 {
                text-align: center;
                font-size: 38px;
                font-weight: 700;
                margin-bottom: 8px;
            }

        .subtitle {
            text-align: center;
            color: #6b7280;
            margin-bottom: 40px;
        }

        .form-label {
            font-weight: 600;
            margin-bottom: 10px;
        }

        /* INPUT */
        .input-group-custom {
            position: relative;
            margin-bottom: 28px;
        }

            .input-group-custom .left-icon {
                position: absolute;
                left: 15px;
                top: 15px;
                color: #9ca3af;
            }

            .input-group-custom .right-icon {
                position: absolute;
                right: 15px;
                top: 15px;
                cursor: pointer;
                color: #6b7280;
            }

        .form-control-custom {
            width: 100%;
            height: 52px;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            padding-left: 45px;
            padding-right: 45px;
            outline: none;
        }

            .form-control-custom:focus {
                border-color: #16a34a;
            }

        /* FORGOT */
        .forgot-password {
            text-align: right;
            margin-top: -10px;
            margin-bottom: 30px;
        }

            .forgot-password a {
                text-decoration: none;
                color: #16a34a;
                font-size: 14px;
                font-weight: 500;
            }

        /* BUTTON */
        .btn-login {
            width: 100%;
            height: 55px;
            border: none;
            border-radius: 6px;
            background: linear-gradient(135deg, #22c55e, #16a34a);
            color: white;
            font-size: 20px;
            font-weight: 600;
        }

            .btn-login:hover {
                background: linear-gradient(135deg, #16a34a, #14532d);
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(22, 163, 74, 0.45);
            }

        /* REGISTER */
        .register-link {
            text-align: center;
            margin-top: 25px;
            font-size: 15px;
        }

            .register-link a {
                color: #16a34a;
                text-decoration: none;
                font-weight: 600;
            }

        /* ERROR */
        .error-message {
            color: red;
            text-align: center;
            margin-bottom: 15px;
            font-size: 14px;
        }

        @@media(max-width: 991px) {

            .login-wrapper {
                flex-direction: column;
            }

            .left-side,
            .right-side {
                width: 100%;
            }

            .left-side {
                height: 450px;
            }
        }

        /* ==========================
                CARD ANIMATION
        ========================== */

        @@keyframes slideInCard {
            from
        {
            opacity: 0;
            transform: translateX(80px);
        }

        to {
            opacity: 1;
            transform: translateX(0)}
        }

        .login-card {
        width: 100%;
        max-width: 470px;
        background: white;
        border: 1px solid #dddddd;
        border-radius: 8px;
        padding: 50px;

        /* Animation */
        opacity: 0;
        animation: slideInCard 0.8s ease-out forwards;
}

    </style>

</head>

<body>

    <div class="main-container">

        <div class="login-wrapper">

            <!-- LEFT -->
            <div class="left-side">

                <div class="top-content">

                    <img src="~/Images/logo.png"
                         alt="Logo" />

                    <h1>
                        SMART OFFICE
                        <br />
                        RECORDS SYSTEM
                    </h1>

                </div>

                <div class="bottom-image">

                    <img src="~/Images/applicant.png"
                         alt="Applicant Image" />

                </div>

            </div>

            <!-- RIGHT -->
            <div class="right-side">

                <div class="login-card">

                    <h2>Welcome Users!</h2>

                    <p class="subtitle">
                        Please sign in to continue.
                    </p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="error-message">
                            @ViewBag.Error
                        </div>
                    }

                    @using (Html.BeginForm(
                                        "ApplicantLogin",
                                        "Applicant",
                                        FormMethod.Post))
                    {

                        <!-- USERNAME -->
                        <label class="form-label">
                            Username
                        </label>

                        <div class="input-group-custom">

                            <i class="bi bi-person left-icon"></i>

                            <input type="text"
                                   name="Username"
                                   class="form-control-custom"
                                   placeholder="Enter Username"
                                   required />

                        </div>

                        <!-- PASSWORD -->
                        <label class="form-label">
                            Password
                        </label>

                        <div class="input-group-custom">

                            <i class="bi bi-lock left-icon"></i>

                            <input type="password"
                                   id="password"
                                   name="Password"
                                   class="form-control-custom"
                                   placeholder="Enter Password"
                                   required />

                            <i class="bi bi-eye right-icon"
                               id="togglePassword"></i>

                        </div>

                        <!-- FORGOT -->
                        <div class="forgot-password">

                            <a href="#">
                                Forgot Password?
                            </a>

                        </div>

                        <!-- BUTTON -->
                        <button type="submit"
                                class="btn-login">

                            Login

                        </button>
                    }

                    <!-- REGISTER -->
                    <div class="register-link">

                        Don’t have an account?

                        <a href="@Url.Action("ApplicantRegister", "Applicant")">
                            Register!
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script>

        const togglePassword =
            document.querySelector("#togglePassword");

        const password =
            document.querySelector("#password");

        togglePassword.addEventListener("click", function () {

            const type =
                password.getAttribute("type") === "password"
                    ? "text"
                    : "password";

            password.setAttribute("type", type);

            this.classList.toggle("bi-eye");
            this.classList.toggle("bi-eye-slash");

        });

    </script>

</body>
</html>