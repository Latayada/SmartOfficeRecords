@{
    ViewBag.Title = "Profile";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile - Smart Office Records System</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Google Fonts (Poppins) -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-green: #16a34a;
            --dark-green: #166534;
            --light-mint: #dcfce7;
            --surface-white: #ffffff;
            --text-dark: #1e293b;
            --border-color: #e2e8f0;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-color: #f8fafc;
            color: var(--text-dark);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* HEADER & NAVIGATION */
        .top-header {
            height: 80px;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(8px);
            position: sticky;
            top: 0;
            z-index: 1000;
            border-bottom: 1px solid var(--border-color);
        }

        .logo-text h4 {
            color: var(--primary-green);
            font-size: 18px;
            font-weight: 700;
            margin: 0;
            line-height: 1.1;
        }

        .logo-text span {
            font-size: 9px;
            font-weight: 600;
            letter-spacing: 1px;
            color: #64748b;
        }

        .nav-menu a {
            text-decoration: none;
            color: #475569;
            font-weight: 500;
            font-size: 14px;
            padding: 8px 16px;
            border-radius: 6px;
            transition: all 0.2s ease;
        }

        .nav-menu a:hover, .nav-menu a.active {
            color: var(--dark-green);
            background: var(--light-mint);
            font-weight: 600;
        }

        /* PROFILE CARD BOX */
        .profile-container {
            max-width: 900px;
            margin: 40px auto;
            width: 100%;
            padding: 0 20px;
        }

        .custom-card {
            background: var(--surface-white);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            box-shadow: 0 4px 20px -2px rgba(15, 23, 42, 0.04);
            padding: 40px;
        }

        .avatar-section {
            background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
            border: 1px dashed var(--primary-green);
            border-radius: 12px;
            padding: 24px;
            text-align: center;
        }

        .form-label {
            font-weight: 500;
            color: #334155;
            font-size: 14px;
            margin-bottom: 6px;
        }

        .form-control-custom {
            height: 48px;
            border: 1px solid #cbd5e1;
            border-radius: 8px;
            padding-left: 14px;
            font-size: 14px;
            background-color: #f8fafc;
            transition: all 0.2s ease;
        }

        .form-control-custom:focus {
            background-color: #fff;
            border-color: #16a34a;
            box-shadow: 0 0 0 4px rgba(22, 163, 74, 0.12);
            outline: none;
        }

        /* BUTTONS */
        .btn-save {
            background: linear-gradient(135deg, #22c55e, #16a34a);
            color: white;
            font-weight: 600;
            padding: 12px 30px;
            border-radius: 8px;
            border: none;
            box-shadow: 0 4px 12px rgba(22, 163, 74, 0.2);
            transition: all 0.2s ease;
        }

        .btn-save:hover {
            background: linear-gradient(135deg, #16a34a, #15803d);
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(22, 163, 74, 0.3);
        }

        /* FOOTER */
        footer {
            background: #166534;
            color: #dcfce7;
            padding: 30px 0;
            margin-top: auto;
        }
    </style>
</head>

<body>

    <!-- HEADER -->
    <div class="top-header">
        <div class="container h-100 d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                <img src="~/Images/logo.png" alt="SORS Logo" style="width: 40px;">
                <div class="logo-text">
                    <h4>SMART OFFICE</h4>
                    <span>RECORDS SYSTEM</span>
                </div>
            </div>

            <div class="nav-menu d-flex align-items-center gap-2">
                <a href="@Url.Action("ApplicantDashboard", "Applicant")"><i class="bi bi-briefcase me-1"></i> Available Work</a>
                <a href="#" class="active"><i class="bi bi-person-gear me-1"></i> Edit Profile</a>
                <div class="dropdown ms-2">
                    <button class="btn btn-sm btn-outline-success dropdown-toggle fw-bold" type="button" data-bs-toggle="dropdown">
                        <i class="bi bi-person-circle me-1"></i> Account
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item text-danger" href="@Url.Action("ApplicantLogin", "Applicant")"><i class="bi bi-box-arrow-left me-2"></i>Sign Out</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- MAIN PROFILE CONTENT -->
    <div class="container profile-container">
        
        <div class="mb-4">
            <h3 class="fw-bold text-success mb-1">Manage Profile Settings</h3>
            <p class="text-muted small">Update your official application details and keep your digital verification identity documents up to date.</p>
        </div>

        @if (ViewBag.SuccessMessage != null)
        {
            <div class="alert alert-success d-flex align-items-center rounded-3 mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                <div>@ViewBag.SuccessMessage</div>
            </div>
        }

        <div class="custom-card">
            @using (Html.BeginForm("UpdateProfile", "Applicant", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                <div class="row g-4">
                    
                    <!-- LEFT COLUMN: PHOTO/ID UPLOAD AREA -->
                    <div class="col-md-4">
                        <div class="avatar-section h-100 d-flex flex-column justify-content-center align-items-center">
                            <i class="bi bi-card-image text-success mb-2" style="font-size: 48px;"></i>
                            <h6 class="fw-bold text-dark mb-1">Identity Card Verification</h6>
                            <p class="text-muted small mb-3" style="font-size: 11px;">Upload a crisp, clear snapshot of a Government ID or School Regalia Card.</p>
                            
                            <input type="file" id="idUpload" name="IdentityCardFile" class="d-none" accept="image/*,.pdf" />
                            <button type="button" class="btn btn-sm btn-success px-3 rounded-2 fw-semibold" onclick="document.getElementById('idUpload').click();">
                                <i class="bi bi-upload me-1"></i> Choose File
                            </button>
                            <span id="fileNameDisplay" class="text-muted mt-2 d-block small" style="font-size: 11px;">No file selected</span>
                        </div>
                    </div>

                    <!-- RIGHT COLUMN: PERSONAL INFO FORMS -->
                    <div class="col-md-8">
                        <h5 class="fw-bold text-dark border-bottom pb-2 mb-3"><i class="bi bi-person-vcard text-success me-2"></i>Personal Data</h5>
                        
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label class="form-label">Full Name</label>
                                <input type="text" name="FullName" class="form-control form-control-custom" value="@Model.FullName" placeholder="Enter Full Name" required />
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label">Email Address</label>
                                <input type="email" name="Email" class="form-control form-control-custom" value="@Model.Email" placeholder="name@example.com" required />
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label">Contact Number</label>
                                <input type="text" name="ContactNumber" class="form-control form-control-custom" value="@Model.ContactNumber" placeholder="09XXXXXXXXX" required />
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label">Username</label>
                                <input type="text" name="Username" class="form-control form-control-custom" value="@Model.Username" readonly />
                            </div>
                        </div>

                        <h5 class="fw-bold text-dark border-bottom pb-2 mt-4 mb-3"><i class="bi bi-shield-lock text-success me-2"></i>Security Parameters</h5>
                        
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <label class="form-label">New Password</label>
                                <input type="password" name="NewPassword" class="form-control form-control-custom" placeholder="Leave blank to keep old password" />
                            </div>
                            <div class="col-sm-6">
                                <label class="form-label">Confirm Password</label>
                                <input type="password" name="ConfirmPassword" class="form-control form-control-custom" placeholder="Repeat new password" />
                            </div>
                        </div>
                    </div>

                </div>

                <!-- FORM BUTTONS BAR -->
                <div class="d-flex justify-content-end gap-2 border-top pt-4 mt-4">
                    <a href="@Url.Action("ApplicantDash", "Applicant")" class="btn btn-sm btn-light border px-4 rounded-2 fw-semibold d-flex align-items-center">Cancel</a>
                    <button type="submit" class="btn-save btn-sm rounded-2">
                        <i class="bi bi-check-lg me-1"></i> Save Structural Profiles
                    </button>
                </div>
            }
        </div>
    </div>

    <!-- FOOTER -->
    <footer>
        <div class="container text-center small opacity-75">
            <p class="mb-1">© 2026 Smart Office Records System. All rights reserved.</p>
            <p class="mb-0">Designed & Developed by JJJC</p>
        </div>
    </footer>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Simple file label indicator script -->
    <script>
        document.getElementById('idUpload').addEventListener('change', function() {
            const fileName = this.files[0] ? this.files[0].name : "No file selected";
            document.getElementById('fileNameDisplay').innerText = fileName;
        });
    </script>
</body>
</html>