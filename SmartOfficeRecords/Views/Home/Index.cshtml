@{
    ViewBag.Title = "Landing Page";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Smart Office Records System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        html, body {
            width: 100%;
            height: 100%;
            overflow: hidden; /* Force zero scrolling */
            background: #ffffff;
            position: relative;
        }

            /* Ambient Wave Backgrounds */
            body::before {
                content: "";
                position: absolute;
                bottom: 0;
                left: 0;
                width: 50vw;
                height: 40vh;
                background: radial-gradient(circle at bottom left, rgba(37, 99, 235, 0.18) 0%, rgba(59, 130, 246, 0.05) 50%, transparent 70%);
                z-index: 0;
                pointer-events: none;
            }

            body::after {
                content: "";
                position: absolute;
                bottom: 0;
                right: 0;
                width: 50vw;
                height: 40vh;
                background: radial-gradient(circle at bottom right, rgba(22, 163, 74, 0.15) 0%, rgba(34, 197, 94, 0.04) 50%, transparent 70%);
                z-index: 0;
                pointer-events: none;
            }

        .bg-glow-top-left {
            position: absolute;
            top: 0;
            left: 0;
            width: 50vw;
            height: 50vh;
            background: radial-gradient(circle at top left, rgba(37, 99, 235, 0.03) 0%, transparent 60%);
            z-index: 0;
            pointer-events: none;
        }

        .bg-glow-top-right {
            position: absolute;
            top: 0;
            right: 0;
            width: 40vw;
            height: 40vh;
            background: radial-gradient(circle at top right, rgba(22, 163, 74, 0.02) 0%, transparent 60%);
            z-index: 0;
            pointer-events: none;
        }

        /* NEW: Central Vibrant Gradient Circle Feature */
        .center-gradient-circle {
            position: absolute;
            width: 580px;
            height: 580px;
            background: radial-gradient(circle, rgba(37, 99, 235, 0.07) 0%, rgba(16, 185, 129, 0.04) 45%, transparent 70%);
            top: 48%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 0;
            pointer-events: none;
            border-radius: 50%;
            filter: blur(20px);
        }

        .landing-wrapper {
            width: 100%;
            height: 100vh; /* Locked to screen height */
            position: relative;
            z-index: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        /* Header Layout */
        .top-header {
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 60px;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(229, 231, 235, 0.5);
            flex-shrink: 0; /* Prevents header from collapsing */
        }

        .logo-section {
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .logo-section img {
                width: 42px;
                height: 42px;
                object-fit: contain;
            }

            .logo-section h4 {
                color: #1d4ed8;
                font-size: 20px;
                font-weight: 700;
                margin: 0;
                letter-spacing: 0.5px;
            }

        .top-secure-badge {
            display: flex;
            align-items: center;
            gap: 12px;
            background: #eff6ff;
            padding: 8px 18px;
            border-radius: 12px;
            border: 1px solid rgba(59, 130, 246, 0.15);
        }

            .top-secure-badge i {
                color: #2563eb;
                font-size: 18px;
            }

            .top-secure-badge div {
                font-size: 12px;
                color: #4b5563;
                line-height: 1.4;
            }

            .top-secure-badge strong {
                color: #1e40af;
                display: block;
                font-weight: 600;
            }

        /* Content Structure */
        .content-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-evenly; /* Better vertical balancing without scrolling */
            align-items: center;
            padding: 20px;
            position: relative;
            overflow: hidden;
        }

        .header-text {
            text-align: center;
            margin-bottom: 15px;
            position: relative;
            z-index: 2;
        }

            .header-text p {
                font-size: 16px;
                color: #4b5563;
                font-weight: 500;
                margin-bottom: 4px;
            }

            .header-text h1 {
                font-size: 42px;
                font-weight: 800;
                margin-bottom: 4px;
            }

                .header-text h1 span {
                    background: linear-gradient(to right, #1d4ed8 45%, #10b981 100%);
                    -webkit-background-clip: text;
                    -webkit-text-fill-color: transparent;
                }

            .header-text .sub-txt {
                font-size: 15px;
                color: #6b7280;
                font-weight: 400;
            }

        /* Grid Cards Panel */
        .cards-container {
            display: flex;
            justify-content: center;
            gap: 40px;
            flex-wrap: nowrap; /* Avoids breaking layouts into extra vertical space */
            margin-bottom: 20px;
            position: relative;
            z-index: 5;
        }

        .login-card {
            width: 340px;
            background: #ffffff;
            border: 1px solid #e5e7eb;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.02);
            transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease;
            overflow: hidden;
        }

            .login-card:hover {
                transform: translateY(-8px);
            }

        .admin-card:hover {
            box-shadow: 0 20px 35px rgba(37, 99, 235, 0.12);
        }

        .applicant-card:hover {
            box-shadow: 0 20px 35px rgba(16, 185, 129, 0.12);
        }

        /* Custom High-Fidelity Mock Illustration Containers */
        .card-illustration-box {
            height: 170px; /* Scaled down slightly to save view height */
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .admin-card .card-illustration-box {
            background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
        }

        .applicant-card .card-illustration-box {
            background: linear-gradient(135deg, #064e3b 0%, #10b981 100%);
        }

        /* Abstract Vector Graphics inside card visuals */
        .mock-overlay-graphic {
            position: absolute;
            bottom: -20px;
            width: 110%;
            height: 60px;
            background: #ffffff;
            border-top-left-radius: 50% 40px;
            border-top-right-radius: 50% 40px;
        }

        .card-user-avatar {
            width: 54px;
            height: 54px;
            border-radius: 50%;
            background: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            position: absolute;
            bottom: 12px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 3;
            box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        }

        .admin-card .card-user-avatar i {
            color: #2563eb;
            font-size: 24px;
        }

        .applicant-card .card-user-avatar i {
            color: #10b981;
            font-size: 24px;
        }

        .mock-laptop-vector {
            width: 140px;
            height: 85px;
            background: rgba(255, 255, 255, 0.15);
            border: 1px solid rgba(255, 255, 255, 0.25);
            border-radius: 8px;
            padding: 8px;
            display: flex;
            flex-direction: column;
            gap: 5px;
            margin-bottom: 25px;
        }

        .mock-screen-row {
            height: 6px;
            background: rgba(255, 255, 255, 0.4);
            border-radius: 3px;
        }

        /* Main Details */
        .card-body-custom {
            padding: 24px;
            text-align: center;
        }

        .admin-title {
            color: #1e3fae;
            font-size: 21px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .applicant-title {
            color: #15803d;
            font-size: 21px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .card-body-custom p.desc {
            font-size: 13.5px;
            color: #6b7280;
            line-height: 1.6;
            margin-bottom: 20px;
            min-height: 65px;
        }

        /* Actions Layout */
        .btn-admin {
            width: 100%;
            background: #2563eb;
            color: #ffffff;
            border: none;
            padding: 12px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: background 0.2s ease;
        }

            .btn-admin:hover {
                background: #1d4ed8;
                color: #ffffff;
            }

        .btn-applicant {
            width: 100%;
            background: #16a34a;
            color: #ffffff;
            border: none;
            padding: 12px;
            border-radius: 10px;
            font-weight: 600;
            font-size: 15px;
            text-decoration: none;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            transition: background 0.2s ease;
        }

            .btn-applicant:hover {
                background: #15803d;
                color: #ffffff;
            }

        .dropdown-menu {
            border-radius: 10px;
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
            border: 1px solid #e5e7eb;
            padding: 6px;
        }

        .dropdown-item {
            padding: 10px 14px;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 500;
            color: #4b5563;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .dropdown-item i {
                font-size: 16px;
            }

        /* Bottom Feature Grid */
        .bottom-features {
            background: #ffffff;
            border: 1px solid rgba(229, 231, 235, 0.8);
            border-radius: 20px;
            display: flex;
            justify-content: space-around;
            padding: 16px;
            width: 100%;
            max-width: 1100px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.01);
            position: relative;
            z-index: 5;
        }

        .feature-box {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 0 20px;
            flex: 1;
        }

            .feature-box:not(:last-child) {
                border-right: 1px solid #e5e7eb;
            }

        .feature-icon-wrapper {
            width: 42px;
            height: 42px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .f-blue {
            background: #eff6ff;
            color: #2563eb;
        }

        .f-green {
            background: #f0fdf4;
            color: #16a34a;
        }

        .f-orange {
            background: #fff7ed;
            color: #area580c;
        }

        .f-purple {
            background: #faf5ff;
            color: #9333ea;
        }

        .feature-details h6 {
            margin: 0 0 2px 0;
            font-size: 13.5px;
            font-weight: 700;
            color: #1f2937;
        }

        .feature-details p {
            margin: 0;
            font-size: 11px;
            color: #6b7280;
            line-height: 1.4;
        }

        /* Floating Desk Setup & Decoratives */
        .left-floating-desk-setup {
            position: absolute;
            top: 28%;
            left: 3%;
            width: 280px;
            height: 240px;
            z-index: 1;
            pointer-events: none;
        }

        .glass-shelf {
            position: absolute;
            bottom: 10px;
            width: 270px;
            height: 110px;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.7) 0%, rgba(219, 234, 254, 0.4) 100%);
            border: 1px solid rgba(255, 255, 255, 0.9);
            border-radius: 24px;
            transform: perspective(500px) rotateX(45deg);
            box-shadow: 0 30px 50px rgba(37, 99, 235, 0.06), inset 0 0 20px rgba(255, 255, 255, 0.6);
        }

        .desk-laptop {
            position: absolute;
            bottom: 40px;
            left: 75px;
            font-size: 96px;
            color: #64748b;
            filter: drop-shadow(0 15px 20px rgba(0,0,0,0.05));
            z-index: 3;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .laptop-screen-content {
            position: absolute;
            top: 24px;
            left: 21px;
            width: 54px;
            height: 35px;
            background: linear-gradient(135deg, #ffffff 0%, #f1f5f9 100%);
            border-radius: 3px;
            display: flex;
            flex-direction: column;
            padding: 4px;
            gap: 3px;
            box-shadow: inset 0 1px 3px rgba(0,0,0,0.05);
        }

        .screen-chart-mock {
            width: 100%;
            height: 12px;
            background: #3b82f6;
            border-radius: 2px;
        }

        .screen-lines-mock {
            width: 70%;
            height: 3px;
            background: #cbd5e1;
            border-radius: 1px;
        }

        .desk-binders {
            position: absolute;
            bottom: 50px;
            left: 10px;
            display: flex;
            gap: 3px;
            z-index: 2;
        }

        .single-binder {
            width: 15px;
            height: 70px;
            background: linear-gradient(to top, #1d4ed8 0%, #60a5fa 100%);
            border-radius: 4px 4px 2px 2px;
            border: 1px solid rgba(255,255,255,0.2);
            position: relative;
            box-shadow: -4px 4px 8px rgba(0,0,0,0.05);
        }

            .single-binder::after {
                content: "";
                position: absolute;
                top: 15px;
                left: 5px;
                width: 3px;
                height: 25px;
                background: #ffffff;
                opacity: 0.7;
                border-radius: 1px;
            }

        .desk-plant {
            position: absolute;
            bottom: 45px;
            right: 25px;
            z-index: 4;
            font-size: 36px;
            color: #10b981;
            filter: drop-shadow(0 6px 10px rgba(0,0,0,0.04));
        }

        .decorative-ambient-asset {
            position: absolute;
            z-index: 1;
            pointer-events: none;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #ffffff;
            border-radius: 14px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.03);
            border: 1px solid rgba(229, 231, 235, 0.5);
        }

        .asset-shield {
            top: 22%;
            left: 19%;
            width: 46px;
            height: 46px;
            border-radius: 50%;
            color: #3b82f6;
            font-size: 20px;
        }

        .asset-folder {
            top: 32%;
            right: 18%;
            width: 52px;
            height: 52px;
            color: #3b82f6;
            font-size: 22px;
            transform: rotate(12deg);
        }

        .asset-lens {
            top: 38%;
            right: 7%;
            width: 48px;
            height: 48px;
            color: #10b981;
            font-size: 20px;
            transform: rotate(-8deg);
        }

        .asset-doc {
            bottom: 45%;
            right: 14%;
            width: 44px;
            height: 44px;
            color: #3b82f6;
            font-size: 18px;
        }

        .asset-dots-left {
            bottom: 25%;
            left: 2%;
            width: 110px;
            height: 130px;
            background-image: radial-gradient(#cbd5e1 1.5px, transparent 1.5px);
            background-size: 14px 14px;
            opacity: 0.5;
            position: absolute;
        }

        .asset-dots-right {
            top: 24%;
            right: 2%;
            width: 110px;
            height: 130px;
            background-image: radial-gradient(#cbd5e1 1.5px, transparent 1.5px);
            background-size: 14px 14px;
            opacity: 0.4;
            position: absolute;
        }

        /* Responsive Breakpoints */
        @@media (max-width: 1250px) {
            .content-area

        {
            height: 100%;
            overflow-y: auto; 
            justify-content: flex-start;
            gap: 20px;
        }

        .cards-container {
            flex-direction: row;
            gap: 20px;
        }

        .left-floating-desk-setup, .decorative-ambient-asset, .asset-dots-left, .asset-dots-right, .center-gradient-circle {
            display: none !important;
        }
        }

        @@media (max-width: 768px) {
            .cards-container

        {
            flex-direction: column;
        }

        .bottom-features {
            flex-direction: column;
            gap: 15px;
        }

        .feature-box:not(:last-child) {
            border-right: none;
            border-bottom: 1px solid #e5e7eb;
            padding-bottom: 10px;
        }

        }
    </style>
</head>
<body>

    <div class="bg-glow-top-left"></div>
    <div class="bg-glow-top-right"></div>

    <div class="center-gradient-circle"></div>

    <div class="left-floating-desk-setup">
        <div class="glass-shelf"></div>
        <div class="desk-binders">
            <div class="single-binder"></div>
            <div class="single-binder"></div>
            <div class="single-binder"></div>
            <div class="single-binder"></div>
        </div>
        <div class="desk-laptop">
            <i class="bi bi-laptop"></i>
            <div class="laptop-screen-content">
                <div class="screen-chart-mock"></div>
                <div class="screen-lines-mock"></div>
                <div class="screen-lines-mock" style="width: 45%"></div>
            </div>
        </div>
        <div class="desk-plant">
            <i class="bi bi-flower1"></i>
        </div>
    </div>

    <div class="decorative-ambient-asset asset-shield"><i class="bi bi-shield-fill-check"></i></div>
    <div class="decorative-ambient-asset asset-folder"><i class="bi bi-folder-fill"></i></div>
    <div class="decorative-ambient-asset asset-lens"><i class="bi bi-search"></i></div>
    <div class="decorative-ambient-asset asset-doc"><i class="bi bi-file-earmark-text"></i></div>
    <div class="asset-dots-left"></div>
    <div class="asset-dots-right"></div>

    <div class="landing-wrapper">
        <div class="top-header">
            <div class="logo-section">
                <img src="~/Images/logo.png" onerror="this.src='https://cdn-icons-png.flaticon.com/512/3652/3652191.png'" alt="Logo">
                <h4>SMART OFFICE RECORDS SYSTEM</h4>
            </div>
            <div class="top-secure-badge">
                <i class="bi bi-shield-check"></i>
                <div>
                    <strong>Secure. Reliable. Efficient.</strong>
                    Your records, our priority.
                </div>
            </div>
        </div>

        <div class="content-area">
            <div class="header-text">
                <p>Welcome! 👋</p>
                <h1><span>Get Started</span></h1>
                <p class="sub-txt">Choose your login type to continue.</p>
            </div>

            <div class="cards-container">
                <div class="login-card admin-card">
                    <div class="card-illustration-box">
                        <div class="mock-laptop-vector">
                            <div class="mock-screen-row" style="width: 40%; background: #ffffff;"></div>
                            <div class="mock-screen-row" style="width: 85%"></div>
                            <div class="mock-screen-row" style="width: 60%"></div>
                        </div>
                        <div class="mock-overlay-graphic"></div>
                        <div class="card-user-avatar">
                            <i class="bi bi-people-fill"></i>
                        </div>
                    </div>
                    <div class="card-body-custom">
                        <h5 class="admin-title">Admin & Staff Login</h5>
                        <p class="desc">Access the admin dashboard to manage users, records, and system settings.</p>

                        <div class="dropdown">
                            <button class="btn btn-admin dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-lock-fill"></i> Login
                            </button>
                            <ul class="dropdown-menu w-100">
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("Login", "Admin")">
                                        <i class="bi bi-shield-lock-fill"></i> Admin Login
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="@Url.Action("StaffLogin", "Staff")">
                                        <i class="bi bi-person-badge-fill"></i> Staff Login
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="login-card applicant-card">
                    <div class="card-illustration-box">
                        <div class="mock-laptop-vector" style="align-items: center; justify-content: center;">
                            <i class="bi bi-file-person" style="font-size: 32px; color: rgba(255,255,255,0.7);"></i>
                        </div>
                        <div class="mock-overlay-graphic"></div>
                        <div class="card-user-avatar">
                            <i class="bi bi-person-fill-check"></i>
                        </div>
                    </div>
                    <div class="card-body-custom">
                        <h5 class="applicant-title">Applicant Login</h5>
                        <p class="desc">Login to submit requests, track status, and manage your records.</p>

                        <a href="@Url.Action("ApplicantLand", "Applicant")" class="btn btn-applicant">
                            <i class="bi bi-person-fill"></i> Applicant
                        </a>
                    </div>
                </div>
            </div>

            <div class="bottom-features">
                <div class="feature-box">
                    <div class="feature-icon-wrapper f-blue"><i class="bi bi-shield-lock-fill"></i></div>
                    <div class="feature-details">
                        <h6>Secure Access</h6>
                        <p>Role-based authentication keeps data safe.</p>
                    </div>
                </div>
                <div class="feature-box">
                    <div class="feature-icon-wrapper f-green"><i class="bi bi-arrow-repeat"></i></div>
                    <div class="feature-details">
                        <h6>Real-time Updates</h6>
                        <p>Get instant updates on your requests.</p>
                    </div>
                </div>
                <div class="feature-box">
                    <div class="feature-icon-wrapper f-orange"><i class="bi bi-lightning-charge-fill"></i></div>
                    <div class="feature-details">
                        <h6>Efficient Workflow</h6>
                        <p>Streamlined processes for productivity.</p>
                    </div>
                </div>
                <div class="feature-box">
                    <div class="feature-icon-wrapper f-purple"><i class="bi bi-heart-pulse-fill"></i></div>
                    <div class="feature-details">
                        <h6>Dedicated Support</h6>
                        <p>We're here to help you every step.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>