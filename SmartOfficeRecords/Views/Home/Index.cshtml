@{
    ViewBag.Title = "Landing Page";
    Layout = null;
}

<!DOCTYPE html>
<html>
    <head>

        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <title>Smart Office Records System</title>

        <!-- Bootstrap -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

        <!-- Google Font -->
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
              rel="stylesheet">

        <!-- Bootstrap Icons -->
        <link rel="stylesheet"
              href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

        <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Poppins', sans-serif;
            }

            /* BODY */
            body {
                margin: 0;
                padding: 0;
                background-image: url('/Content/Images/lp.png');
                background-size: cover;
                background-position: center;
                background-repeat: no-repeat;
                background-attachment: fixed;
                min-height: 100vh;
            }

            /* MAIN CONTAINER */
            .main-container {
                width: 100%;
                min-height: 100vh;
                background: rgba(255,255,255,0.90);
                overflow: hidden;
            }

            /* NAVBAR */
            .navbar-custom {
                width: 100%;
                height: 85px;
                padding-left: 30px;
                padding-right: 30px;
                border-bottom: 1px solid #e5e5e5;
                display: flex;
                justify-content: space-between;
                align-items: center;
            }

            /* LOGO */
            .logo-section {
                display: flex;
                align-items: center;
                gap: 12px;
            }

                .logo-section img {
                    width: 52px;
                    height: 52px;
                    object-fit: contain;
                }

            .logo-text h2 {
                font-size: 18px;
                font-weight: 700;
                color: #2563eb;
                margin: 0;
                line-height: 1.1;
            }

            .logo-text span {
                font-size: 11px;
                font-weight: 700;
                color: #111827;
                letter-spacing: 0.5px;
            }

            /* NAVIGATION */
            .nav-links a {
                text-decoration: none;
                margin-left: 40px;
                font-size: 15px;
                font-weight: 600;
                color: #2563eb;
                position: relative;
                transition: 0.3s ease;
            }

                /* ONLY TEXT HOVER EFFECT */
                .nav-links a:hover {
                    color: #1e3fae;
                    transform: translateY(-2px);
                }

            /* KEEP HOME UNDERLINE ONLY */
            .nav-links .active::after {
                content: '';
                width: 100%;
                height: 3px;
                background: #2563eb;
                position: absolute;
                left: 0;
                bottom: -8px;
                border-radius: 5px;
            }

            /* REMOVE UNDERLINE EFFECT FROM OTHER LINKS */
            .nav-links a:not(.active)::after {
                display: none;
            }

            /* CONTENT WRAPPER */
            .content-wrapper {
                width: 100%;
                height: calc(92vh - 85px);
                display: flex;
            }

            /* LEFT SIDE */
            .left-side {
                width: 46%;
                height: 100%;
            }

                .left-side img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }

            /* RIGHT SIDE */
            .right-side {
                width: 54%;
                height: 100%;
                background-color: #f8f8f8;
                display: flex;
                flex-direction: column;
                justify-content: center;
                align-items: center;
                padding: 20px 30px;
            }

            /* HEADER */
            .header-text {
                text-align: center;
                margin-bottom: 35px;
            }

                .header-text h1 {
                    font-size: 30px;
                    font-weight: 700;
                    color: #111827;
                    margin-bottom: 5px;
                }

                .header-text p {
                    font-size: 16px;
                    font-weight: 600;
                    color: #374151;
                }

            /* CARD CONTAINER */
            .cards-container {
                display: flex;
                gap: 28px;
            }

            /* LOGIN CARD */
            .login-card {
                width: 310px;
                background-color: white;
                border: 1px solid #dddddd;
                border-radius: 8px;
                overflow: visible;
                transition: 0.3s ease;
            }

                /* HOVER EFFECT */
                .login-card:hover {
                    transform: translateY(-10px);
                    box-shadow: 0 12px 25px rgba(0,0,0,0.15);
                    cursor: pointer;
                }

            /* CARD IMAGE */
            .card-image {
                width: 100%;
                height: 185px;
            }

                .card-image img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                }

            /* CARD BODY */
            .card-body-custom {
                padding: 22px;
                text-align: center;
            }

            /* TITLES */
            .admin-title {
                color: #2563eb;
                font-size: 18px;
                font-weight: 700;
                margin-bottom: 18px;
            }

            .applicant-title {
                color: #16a34a;
                font-size: 18px;
                font-weight: 700;
                margin-bottom: 18px;
            }

            /* PARAGRAPH */
            .card-body-custom p {
                font-size: 14px;
                font-weight: 600;
                color: #374151;
                line-height: 1.7;
                min-height: 80px;
            }

            /* ADMIN BUTTON */
            .btn-admin {
                width: 100%;
                background-color: #2948c7;
                color: white;
                border: none;
                padding: 13px;
                border-radius: 6px;
                font-size: 15px;
                font-weight: 600;
                margin-top: 12px;
            }

                .btn-admin:hover {
                    background-color: #1e3fae;
                    color: white;
                }

        /* Dropdown Container */
        .dropdown {
            width: 100%;
            position: relative;
        }

            /* Login Button */
            .dropdown .btn-admin {
                width: 100%;
            }

        /* Dropdown Menu */
        .dropdown-menu {
            position: absolute;
            top: 100%;
            left: 0;
            width: 100%;
            margin-top: 5px;
            padding: 6px 0;
            border: none;
            border-radius: 6px;
            box-shadow: 0 8px 20px rgba(0,0,0,.15);
            z-index: 9999;
            display: none;
            overflow: hidden;
        }

        /* Show on Hover */
        .dropdown:hover .dropdown-menu {
            display: block;
        }

        /* Dropdown Items */
        .dropdown-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 15px;
            font-size: 14px;
            font-weight: 500;
        }

            .dropdown-item:hover {
                background: #f3f4f6;
            }

        /* Prevent Card from Cutting Dropdown */
        .login-card {
            overflow: visible;
        }

            /* APPLICANT BUTTON */
            .btn-applicant {
                width: 100%;
                background-color: #16a34a;
                color: white;
                border: none;
                padding: 13px;
                border-radius: 6px;
                font-size: 15px;
                font-weight: 600;
                margin-top: 12px;
            }

                .btn-applicant:hover {
                    background-color: #15803d;
                    color: white;
                }

            /* RESPONSIVE */
            @@media(max-width: 1200px) {

                .content-wrapper {
                    flex-direction: column;
                }

                .left-side,
                .right-side {
                    width: 100%;
                }

                .left-side {
                    height: 400px;
                }

                .cards-container {
                    flex-direction: column;
                }
            }

        </style>

    </head>

    <body>

        <!-- MAIN -->
        <div class="main-container">

            <!-- NAVBAR -->
            <div class="navbar-custom">

                <!-- LOGO -->
                <div class="logo-section">

                    <img src="~/Images/logo.png" alt="Logo" />

                    <div class="logo-text">

                        <h2>SMART OFFICE</h2>
                        <span>RECORDS SYSTEM</span>

                    </div>

                </div>

                <!-- NAV LINKS -->
                <div class="nav-links">

                    <a href="#" class="active">Home</a>
                    <a href="#">About</a>
                    <a href="#">Contact</a>

                </div>

            </div>

            <!-- CONTENT -->
            <div class="content-wrapper">

                <!-- LEFT SIDE -->
                <div class="left-side">

                    <img src="~/Images/lp.png" alt="Landing Page Image" />

                </div>

                <!-- RIGHT SIDE -->
                <div class="right-side">

                    <!-- HEADER -->
                    <div class="header-text">

                        <h1>Get Started</h1>

                        <p>
                            Choose your login type to continue.
                        </p>

                    </div>

                    <!-- CARDS -->
                    <div class="cards-container">

                        <!-- ADMIN CARD -->
                        <div class="login-card">

                            <!-- IMAGE -->
                            <div class="card-image">

                                <img src="~/Images/admin.png"
                                     alt="Admin Image" />

                            </div>

                            <!-- BODY -->
                            <div class="card-body-custom">

                                <h3 class="admin-title">
                                    Admin and Staff
                                </h3>

                                <p>
                                    Access the dashboard to manage users,
                                    records, and system settings based on
                                    your assigned permissions.
                                </p>

                            <div class="dropdown">

                                <button class="btn btn-admin dropdown-toggle"
                                        type="button">

                                    <i class="bi bi-lock-fill"></i>

                                    &nbsp; Login

                                </button>

                                <ul class="dropdown-menu w-100">

                                    <li>
                                        <a class="dropdown-item"
                                           href="@Url.Action("Login", "Admin")">

                                            <i class="bi bi-shield-lock-fill"></i>
                                            Admin Login

                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                           href="@Url.Action("StaffLogin", "Staff")">

                                            <i class="bi bi-person-badge-fill"></i>
                                            Staff Login

                                        </a>
                                    </li>

                                </ul>

                            </div>

                            </div>

                        </div>

                        <!-- APPLICANT CARD -->
                        <div class="login-card">

                            <!-- IMAGE -->
                            <div class="card-image">

                                <img src="~/Images/applicant.png"
                                     alt="Applicant Image" />

                            </div>

                            <!-- BODY -->
                            <div class="card-body-custom">

                                <h3 class="applicant-title">
                                    Applicant Login
                                </h3>

                                <p>
                                    Login to submit requests,
                                    track status, and manage
                                    your records.
                                </p>

                                <a href="/Applicant/ApplicantLogin"
                                   class="btn btn-applicant">

                                    <i class="bi bi-person-fill"></i>

                                    &nbsp; Applicant Login

                                </a>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </body>
</html>