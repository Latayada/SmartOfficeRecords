@{
    ViewBag.Title = "Landing Page";
    Layout = null;
}

<!DOCTYPE html>
<html>
    <head>

        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0">

        <title>Smart Office Records System</title>

        <!-- Bootstrap -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

        <!-- Google Font -->
        <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
              rel="stylesheet">

        <!-- Bootstrap Icons -->
        <link rel="stylesheet"
              href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

        <style>

            * {
                margin: 0;
                padding: 0;
                box-sizing: border-box;
                font-family: 'Poppins', sans-serif;
            }

            /* BODY */
        html,
        body {
            width: 100%;
            height: 100%;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
            font-family: 'Poppins', sans-serif;
            background: #f3f4f6;
        }

        .landing-container {
            width: 100vw;
            height: 100vh;
            background: #fff;
            border: none;
            margin: 0;
        }

        .landing-wrapper {
            display: flex;
            justify-content: center;
        }

        .page-title {
            margin-bottom: 10px;
            color: #9ca3af;
            font-size: 14px;
        }
        
        .top-header {
            height: 70px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            align-items: center;
            padding: 0 25px;
        }

        .logo-section {
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .logo-section img {
                width: 40px;
            }

            .logo-section h4 {
                color: #2563eb;
                font-size: 26px;
                font-weight: 700;
                margin: 0;
            }

        .content-area {
            height: calc(100vh - 70px);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .header-text {
            text-align: center;
            margin-bottom: 40px;
        }

            .header-text h1 {
                font-size: 32px;
                font-weight: 700;
                margin-bottom: 5px;
            }

            .header-text p {
                font-size: 16px;
                color: #374151;
                font-weight: 500;
            }

        .cards-container {
            display: flex;
            justify-content: center;
            gap: 30px;
            flex-wrap: wrap;
        }

        .login-card {
            width: 290px;
            border: 1px solid #dbe2ea;
            border-radius: 6px;
            overflow: visible;
            background: #fff;
            transition: all 0.3s ease;
            cursor: pointer;
        }

            .login-card:hover {
                transform: translateY(-10px);
                box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
            }

            .login-card img {
                width: 100%;
                height: 180px;
                object-fit: cover;
                transition: transform 0.3s ease;
            }

            .login-card:hover img {
                transform: scale(1.05);
            }

        .admin-card:hover {
            box-shadow: 0 15px 35px rgba(37, 99, 235, 0.25);
        }

        .applicant-card:hover {
            box-shadow: 0 15px 35px rgba(22, 163, 74, 0.25);
        }

        .card-body-custom {
            padding: 20px;
            text-align: center;
        }

        .admin-title {
            color: #2563eb;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .applicant-title {
            color: #16a34a;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .card-body-custom p {
            min-height: 70px;
            font-size: 14px;
            color: #374151;
        }

        .btn-admin {
            width: 100%;
            background: #2948c7;
            color: white;
            border: none;
            padding: 12px;
        }

            .btn-admin:hover {
                background: #1e3fae;
                color: white;
            }

        .btn-applicant {
            width: 100%;
            background: #16a34a;
            color: white;
            padding: 12px;
            border: none;
        }

            .btn-applicant:hover {
                background: #15803d;
                color: white;
            }

        .dropdown {
            position: relative;
        }

            .dropdown:hover .dropdown-menu {
                display: block;
            }

        /* Prevent Card from Cutting Dropdown */
        .login-card {
            overflow: visible;
        }

            /* APPLICANT BUTTON */
            .btn-applicant {
                width: 100%;
                background-color: #16a34a;
                color: white;
                border: none;
                padding: 13px;
                border-radius: 6px;
                font-size: 15px;
                font-weight: 600;
                margin-top: 12px;
            }

                .btn-applicant:hover {
                    background-color: #15803d;
                    color: white;
                }

            /* RESPONSIVE */
            @@media(max-width: 1200px) {

                .content-wrapper {
                    flex-direction: column;
                }

                .left-side,
                .right-side {
                    width: 100%;
                }

                .left-side {
                    height: 400px;
                }

                .cards-container {
                    flex-direction: column;
                }
            }

        </style>

    </head>

<body>

    <div class="landing-wrapper">

        <div class="landing-container">

            <!-- Header -->
            <div class="top-header">

                <div class="logo-section">
                    <img src="~/Images/logo.png" alt="Logo">

                    <h4>SMART OFFICE RECORDS SYSTEM</h4>
                </div>

            </div>

            <!-- Content -->
            <div class="content-area">

                <div class="header-text">

                    <h1>Get Started</h1>

                    <p>Choose your login type to continue.</p>

                </div>

                <div class="cards-container">

                    <!-- Admin Card -->
                    <div class="login-card admin-card">

                        <img src="~/Images/admin.png"
                             class="card-img-top"
                             alt="Admin">

                        <div class="card-body-custom">

                            <h5 class="admin-title">
                                Admin & Staff Login
                            </h5>

                            <p>
                                Access the admin dashboard to manage users,
                                records, and system settings.
                            </p>

                            <div class="dropdown">

                                <button class="btn btn-admin dropdown-toggle"
                                        type="button">

                                    <i class="bi bi-lock-fill"></i>
                                    Login

                                </button>

                                <ul class="dropdown-menu w-100">

                                    <li>
                                        <a class="dropdown-item"
                                           href="@Url.Action("Login", "Admin")">

                                            <i class="bi bi-shield-lock-fill"></i>
                                            Admin Login

                                        </a>
                                    </li>

                                    <li>
                                        <a class="dropdown-item"
                                           href="@Url.Action("StaffLogin", "Staff")">

                                            <i class="bi bi-person-badge-fill"></i>
                                            Staff Login

                                        </a>
                                    </li>

                                </ul>

                            </div>

                        </div>

                    </div>

                    <!-- Applicant Card -->
                    <div class="login-card applicant-card">

                        <img src="~/Images/applicant.png"
                             class="card-img-top"
                             alt="Applicant">

                        <div class="card-body-custom">

                            <h5 class="applicant-title">
                                Applicant Login
                            </h5>

                            <p>
                                Login to submit requests, track status,
                                and manage your records.
                            </p>

                            <a href="/Applicant/ApplicantLogin"
                               class="btn btn-applicant">

                                <i class="bi bi-person-fill"></i>
                                Applicant

                            </a>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>
</html>