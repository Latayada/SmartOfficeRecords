@{
    ViewBag.Title = "Staff Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Staff Dashboard</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: #f4f6f9;
            overflow: hidden;
        }

        /* ==========================
                       DASHBOARD DESIGN
                   ===========================*/

        .dashboard-container {
            display: flex;
            height: 100vh;
        }

        /* ==========================
                        SIDEBAR DESIGN
                  ===========================*/
        .sidebar {
            width: 190px;
            background-color: #2980B9;
            color: white;
            display: flex;
            flex-direction: column;
            transition: all .3s ease;
            height: 100vh;
            overflow-y: auto; 
            overflow-x: hidden; 
        }

        .sidebar {
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,.3) transparent;
        }

            /* Chrome / Edge */
            .sidebar::-webkit-scrollbar {
                width: 6px;
            }

            .sidebar::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,.25);
                border-radius: 10px;
            }

            .sidebar::-webkit-scrollbar-track {
                background: transparent;
            }

            /* ==========================
                        COLLAPSED SIDEBAR
                   ===========================*/
            .sidebar.collapsed {
                width: 90px;
            }

                /* Keep SORS visible */
                .sidebar.collapsed .system-name {
                    display: block;
                    font-size: 12px;
                    font-weight: 600;
                    margin-top: 10px;
                }

                /* Logo size when collapsed */
                .sidebar.collapsed .logo-circle {
                    width: 58px;
                    height: 58px;
                }

                /* Keep divider line */
                .sidebar.collapsed .logo-section {
                    padding: 25px 15px;
                    border-bottom: 1px solid rgba(255,255,255,.15);
                }

                /* Hide menu text only */
                .sidebar.collapsed .menu a span,
                .sidebar.collapsed .logout a span {
                    display: none;
                }

                /* Menu layout */
                .sidebar.collapsed .menu {
                    padding: 20px 12px;
                }

                    /* Menu items */
                    .sidebar.collapsed .menu a {
                        width: 50px;
                        height: 50px;
                        margin: 0 auto 18px auto;
                        padding: 0;
                        display: flex;
                        justify-content: center;
                        align-items: center;
                        border-radius: 8px;
                    }

                        /* Active menu */
                        .sidebar.collapsed .menu a.active {
                            background: #4FC3F7;
                            box-shadow: 0 4px 10px rgba(0,0,0,.15);
                        }

                        /* Keep icon size same as expanded */
                        .sidebar.collapsed .menu a i,
                        .sidebar.collapsed .logout a i {
                            margin: 0;
                            font-size: inherit;
                        }

                /* Logout */
                .sidebar.collapsed .logout {
                    margin-top: auto;
                    padding-bottom: 20px;
                }

                    .sidebar.collapsed .logout a {
                        width: 50px;
                        height: 50px;
                        margin: 0 auto;
                        padding: 0;
                        display: flex;
                        justify-content: center;
                        align-items: center;
                    }


        /* ================
                       SETTINGS DROPDOWN
                   ====================== */

        .sidebar-dropdown {
            margin-bottom: 10px;
        }

        .dropdown-toggle-menu {
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 6px;
            cursor: pointer;
        }

            .dropdown-toggle-menu:hover {
                background: rgba(255,255,255,.12);
            }

        .small-arrow {
            font-size: 12px;
            transition: transform .3s ease;
        }

        /* submenu */
        .dropdown-submenu {
            display: none;
            flex-direction: column;
            padding-left: 20px;
        }

            .dropdown-submenu a {
                color: white;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 10px 12px;
                font-size: 14px;
                border-radius: 6px;
            }

                .dropdown-submenu a:hover {
                    background: rgba(255,255,255,.12);
                }

        /* active state */
        .sidebar-dropdown.open .dropdown-submenu {
            display: flex;
        }

        .sidebar-dropdown.open .small-arrow {
            transform: rotate(180deg);
        }

        /* Hide dropdown arrow when sidebar is collapsed */
        .sidebar.collapsed .small-arrow {
            display: none;
        }

        /* ==========================
                          LOGO DESIGN
                   ===========================*/
        .logo-section {
            text-align: center;
            padding: 25px 15px;
            border-bottom: 1px solid rgba(255, 255, 255, .15);
        }

        .logo-circle {
            width: 60px;
            height: 60px;
            background: white;
            border-radius: 50%;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .logout {
            margin-top: auto;
            padding: 15px 12px;
        }

            .logout a {
                color: white;
                text-decoration: none;
                display: flex;
                gap: 12px;
                align-items: center;
                padding: 12px 14px;
            }

        .system-name {
            margin-top: 12px;
            font-size: 14px;
            font-weight: 600;
        }
        /* ==========================
                         MENU DESIGN
                   ===========================*/

        .menu {
            padding: 20px 12px;
        }

            .menu a {
                color: white;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 14px;
                margin-bottom: 10px;
                border-radius: 6px;
            }

                .menu a:hover {
                    background: rgba(255,255,255,.12);
                }

                .menu a.active {
                    background: #4FC3F7;
                }

        /* ==========================
                            MAIN CONTENT
                    ===========================*/

        .main-content {
            flex: 1;
            background: #f4f6f9;
        }

        /* ==========================
                            TOP BAR
                   ===========================*/
        .topbar {
            height: 60px;
            border-bottom: 1px solid #d9dce3;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
            background: #fff;
        }

        .menu-toggle {
            background: none;
            border: none;
            color: #2980B9;
            font-size: 22px;
            cursor: pointer;
            margin-right: 10px;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 18px;
            margin-right: 8px;
        }

            .topbar-left i {
                font-size: 28px;
                color: #2980B9;
                cursor: pointer;
                margin: 8px;
            }

            .topbar-left h3 {
                color: #2980B9;
                font-weight: 700;
                margin: 0;
            }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-left: auto;
        }

            .topbar-right i {
                font-size: 24px;
                cursor: pointer;
            }

        .profile {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .profile img {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                object-fit: cover;
            }

        .profile-info {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

            .profile-info .role {
                font-size: 12px;
                color: #777;
            }

            .profile-info h5 {
                margin: 0;
                font-size: 14px;
                font-weight: 600;
                color: #5DADE2;
            }

            .profile-info span {
                font-size: 12px;
                color: gray;
            }

        /* CONTENT */
        .content-area {
            padding: 30px;
        }

        /* CARDS */
        .cards-container {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
        }

        .dashboard-card {
            width: 227px;
            height: 100px;
            background: white;
            border: 1px solid #e5e5e5;
            border-radius: 10px;
            display: flex;
            align-items: center;
            padding: 20px;
            gap: 15px;
        }

        .card-icon {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            font-size: 22px;
        }

        .purple {
            background: #7e22ce;
        }

        .orange {
            background: #f59e0b;
        }

        .green {
            background: #10b981;
        }

        .blue {
            background: #3b82f6;
        }

        .red {
            background: #ef4444;
        }

        .card-info h2 {
            margin: 0;
            font-size: 34px;
            font-weight: 700;
        }

        .card-info span {
            font-size: 14px;
            font-weight: 600;
        }

        /* GRAPH SECTION */
        .graph-section {
            margin-top: 35px;
            background: white;
            border-radius: 10px;
            padding: 25px;
            height: 420px;
        }

        .graph-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

            .graph-header h4 {
                font-size: 22px;
                font-weight: 700;
            }

        .filter-btn {
            border: 1px solid #d1d5db;
            background: white;
            padding: 10px 20px;
            border-radius: 8px;
            font-weight: 600;
        }

        .graph-placeholder {
            width: 100%;
            height: 280px;
            border-left: 2px solid black;
            border-bottom: 2px solid black;
            position: relative;
        }

        .days {
            position: absolute;
            bottom: -35px;
            width: 100%;
            display: flex;
            justify-content: space-around;
            font-weight: 600;
        }

    </style>

</head>

<body>

    <div class="dashboard-container">

        <!-- SIDEBAR -->
        <aside class="sidebar">

            <div class="logo-section">

                <div class="logo-circle">
                    <img src="~/Images/logo.png" class="logo-img">
                </div>

                <div class="system-name">
                    SORS
                </div>

            </div>

            <div class="menu">

                <a href="@Url.Action("Dashboard", "Staff")" class="active">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>

                <a href="@Url.Action("RequestManagement", "Staff")">
                    <i class="bi bi-file-earmark-text"></i>
                    <span>Request</span>
                </a>

                <a href="@Url.Action("RecordsManagement", "Staff")">
                    <i class="bi bi-folder2-open"></i>
                    <span>Records</span>
                </a>

                <a href="@Url.Action("ReportsManagement", "Staff")">
                    <i class="bi bi-clipboard-data"></i>
                    <span>Reports</span>
                </a>

                <!-- SETTINGS DROPDOWN -->
                <div class="sidebar-dropdown">

                    <a href="javascript:void(0)" class="dropdown-toggle-menu">
                        <i class="bi bi-gear"></i>
                        <span>Settings</span>
                        <i class="bi bi-caret-down-fill ms-auto small-arrow"></i>
                    </a>

                    <div class="dropdown-submenu">

                        <a href="@Url.Action("Settings", "Admin")">
                            <i class="bi bi-sliders"></i>
                            <span>General Settings</span>
                        </a>

                        <a href="@Url.Action("SAccountSettings", "Admin")">
                            <i class="bi bi-person-gear"></i>
                            <span>Account & Security</span>
                        </a>
                    </div>

                </div>

            </div>

            <div class="logout">

                <a href="@Url.Action("Login", "Admin")">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Logout</span>
                </a>

            </div>

        </aside>

        <!-- MAIN -->
        <div class="main-content">

            <!-- TOPBAR -->
            <div class="topbar">

                <div class="topbar-left">
                    <button class="menu-toggle" id="menuToggle">
                        <i class="bi bi-list"></i>
                    </button>


                </div>

                <div class="topbar-right">

                    <i class="bi bi-bell-fill"></i>

                    <div class="profile">

                        <img src="~/Images/adminpic.jpg" alt="Profile" />

                        <div class="profile-info">
                            <span class="role">Administrator</span>
                            <h5>Juan Dela Cruz</h5>
                        </div>

                    </div>

                </div>

            </div>

            <!-- CONTENT -->
            <div class="content-area">

                <!-- CARDS -->
                <div class="cards-container">

                    <div class="dashboard-card">

                        <div class="card-icon purple">
                            <i class="bi bi-send-fill"></i>
                        </div>

                        <div class="card-info">
                            <h2>0</h2>
                            <span style="color:#7e22ce;">
                                Total Request
                            </span>
                        </div>

                    </div>

                    <div class="dashboard-card">

                        <div class="card-icon orange">
                            <i class="bi bi-clock"></i>
                        </div>

                        <div class="card-info">
                            <h2>0</h2>
                            <span style="color:#f59e0b;">
                                Pendings
                            </span>
                        </div>

                    </div>

                    <div class="dashboard-card">

                        <div class="card-icon green">
                            <i class="bi bi-check-circle"></i>
                        </div>

                        <div class="card-info">
                            <h2>0</h2>
                            <span style="color:#10b981;">
                                Approved
                            </span>
                        </div>

                    </div>

                    <div class="dashboard-card">

                        <div class="card-icon blue">
                            <i class="bi bi-file-earmark-text"></i>
                        </div>

                        <div class="card-info">
                            <h2>0</h2>
                            <span style="color:#3b82f6;">
                                Completed
                            </span>
                        </div>

                    </div>

                    <div class="dashboard-card">

                        <div class="card-icon red">
                            <i class="bi bi-x-circle"></i>
                        </div>

                        <div class="card-info">
                            <h2>0</h2>
                            <span style="color:#ef4444;">
                                Rejected
                            </span>
                        </div>

                    </div>

                </div>

                <!-- GRAPH -->
                <div class="graph-section">

                    <div class="graph-header">

                        <h4>Request Overview</h4>

                        <button class="filter-btn">
                            This Week
                            <i class="bi bi-caret-down-fill"></i>
                        </button>

                    </div>

                    <div class="graph-placeholder">

                        <div class="days">

                            <span>Mon</span>
                            <span>Tue</span>
                            <span>Wed</span>
                            <span>Thu</span>
                            <span>Fri</span>
                            <span>Sat</span>
                            <span>Sun</span>

                        </div>

                    </div>

                </div>

            </div>
        </div>

    </div>

    <script>
        const dropdown = document.querySelector('.sidebar-dropdown');
            const toggle = document.querySelector('.dropdown-toggle-menu');

        toggle.addEventListener('click', function () {
            dropdown.classList.toggle('open');
        });

        const sidebar = document.querySelector('.sidebar');
        const toggleBtn = document.getElementById('menuToggle');

        toggleBtn.addEventListener('click', function () {
            sidebar.classList.toggle('collapsed');
        });
    </script>

</body>
</html>