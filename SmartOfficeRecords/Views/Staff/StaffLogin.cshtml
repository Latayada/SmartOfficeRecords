@{
    ViewBag.Title = "Staff Login";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Staff Login</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: #f3f4f6;
            min-height: 100vh;
            overflow: hidden;
        }

        .main-container {
            width: 100%;
            height: 100vh;
            display: flex;
        }

        .login-wrapper {
            width: 100%;
            height: 100vh;
            background: white;
            display: flex;
            overflow: hidden;
        }

        /* LEFT SIDE */
        .left-side {
            width: 40%;
            height: 100vh;
            background: #243f99;
            position: relative;
        }

        .top-content {
            text-align: center;
            padding-top: 60px;
            z-index: 2;
            position: relative;
        }

            .top-content img {
                width: 120px;
                margin-bottom: 25px;
            }

            .top-content h1 {
                color: white;
                font-size: 42px;
                font-weight: 700;
                line-height: 1.2;
            }

        .bottom-image {
            position: absolute;
            bottom: 0;
            width: 100%;
        }

            .bottom-image img {
                width: 100%;
                height: 55vh;
                object-fit: cover;
            }

        /* RIGHT SIDE */
        .right-side {
            width: 60%;
            height: 100vh;
            background: #f8f8f8;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px;
        }

        /* LOGIN CARD */
        .login-card {
            width: 100%;
            max-width: 450px;
            background: white;
            border: 1px solid #dddddd;
            border-radius: 8px;
            padding: 45px;
        }

            .login-card h2 {
                text-align: center;
                font-size: 36px;
                font-weight: 700;
                margin-bottom: 8px;
            }

        .subtitle {
            text-align: center;
            color: #6b7280;
            margin-bottom: 35px;
        }

        .form-label {
            font-weight: 600;
            margin-bottom: 10px;
        }

        .input-group-custom {
            position: relative;
            margin-bottom: 25px;
        }

            .input-group-custom .left-icon {
                position: absolute;
                left: 15px;
                top: 15px;
                color: #9ca3af;
            }

            .input-group-custom .right-icon {
                position: absolute;
                right: 15px;
                top: 15px;
                cursor: pointer;
                color: #6b7280;
            }

        .form-control-custom {
            width: 100%;
            height: 52px;
            border: 1px solid #d1d5db;
            border-radius: 6px;
            padding-left: 45px;
            padding-right: 45px;
            outline: none;
        }

            .form-control-custom:focus {
                border-color: #2563eb;
            }


        .btn-login {
            width: 100%;
            height: 55px;
            border: none;
            border-radius: 6px;
            background: #2563eb;
            color: white;
            font-size: 18px;
            font-weight: 600;
        }

            .btn-login:hover {
                background: #1e40af;
            }

        .contact-admin {
            text-align: center;
            margin-top: 25px;
            font-size: 14px;
        }

            .contact-admin a {
                color: #2563eb;
                text-decoration: none;
            }

        .error-message {
            color: red;
            text-align: center;
            margin-bottom: 15px;
            font-size: 14px;
        }

        @@media(max-width: 991px) {

            .login-wrapper {
                flex-direction: column;
            }

            .left-side,
            .right-side {
                width: 100%;
            }
        }

    </style>

</head>

<body>

    <div class="main-container">

        <div class="login-wrapper">

            <!-- LEFT -->
            <div class="left-side">

                <div class="top-content">

                    <img src="~/Images/logo.png" />

                    <h1>
                        SMART OFFICE
                        <br />
                        RECORDS SYSTEM
                    </h1>

                </div>

                <div class="bottom-image">

                    <img src="~/Images/staffl.png" alt="Office Image" />

                </div>

            </div>

            <!-- RIGHT -->
            <div class="right-side">

                <div class="login-card">

                    <h2>Staff Login</h2>

                    <p class="subtitle">
                        Please sign in to continue.
                    </p>

                    @if (ViewBag.Error != null)
                    {
                        <div class="error-message">
                            @ViewBag.Error
                        </div>
                    }

                    @using (Html.BeginForm("StaffLogin", "Staff", FormMethod.Post))
                    {

                        <!-- USERNAME -->
                        <label class="form-label">
                            Username
                        </label>

                        <div class="input-group-custom">

                            <i class="bi bi-person left-icon"></i>

                            <input type="text"
                                   name="Username"
                                   class="form-control-custom"
                                   placeholder="Enter Username"
                                   required />

                        </div>

                        <!-- PASSWORD -->
                        <label class="form-label">
                            Password
                        </label>

                        <div class="input-group-custom">

                            <i class="bi bi-lock left-icon"></i>

                            <input type="password"
                                   id="password"
                                   name="Password"
                                   class="form-control-custom"
                                   placeholder="Enter Password"
                                   required />

                            <i class="bi bi-eye right-icon"
                               id="togglePassword"></i>

                        </div>


                        <button type="submit"
                                class="btn-login">

                            Login

                        </button>
                    }


                </div>

            </div>

        </div>

    </div>

    <script>

        const togglePassword =
            document.querySelector("#togglePassword");

        const password =
            document.querySelector("#password");

        togglePassword.addEventListener("click", function () {

            const type =
                password.getAttribute("type") === "password"
                    ? "text"
                    : "password";

            password.setAttribute("type", type);

            this.classList.toggle("bi-eye");
            this.classList.toggle("bi-eye-slash");

        });

    </script>

</body>
</html>