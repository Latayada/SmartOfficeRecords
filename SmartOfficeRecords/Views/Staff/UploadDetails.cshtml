@{
    ViewBag.Title = "Upload Record Details";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>Upload Records</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
          rel="stylesheet">

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background: #f4f5f7;
            overflow-x: hidden;
        }

        /* ==========================
           DASHBOARD LAYOUT
        ========================== */

        .dashboard-container {
            display: flex;
            min-height: 100vh;
        }

        /* ==========================
           SIDEBAR
        ========================== */

        .sidebar {
            width: 190px;
            background: #1f3b97;
            color: white;
            display: flex;
            flex-direction: column;
            transition: all .3s ease;
            height: 100vh; /* important */
            overflow-y: auto; /* enable vertical scroll */
            overflow-x: hidden; /* prevent horizontal scroll */
        }

        .sidebar {
            scrollbar-width: thin;
            scrollbar-color: rgba(255,255,255,.3) transparent;
        }

            /* Chrome / Edge */
            .sidebar::-webkit-scrollbar {
                width: 6px;
            }

            .sidebar::-webkit-scrollbar-thumb {
                background: rgba(255,255,255,.25);
                border-radius: 10px;
            }

            .sidebar::-webkit-scrollbar-track {
                background: transparent;
            }

            /* ==========================
                           COLLAPSED SIDEBAR
                       ===========================*/
            .sidebar.collapsed {
                width: 90px;
            }

                /* Keep SORS visible */
                .sidebar.collapsed .system-name {
                    display: block;
                    font-size: 12px;
                    font-weight: 600;
                    margin-top: 10px;
                }

                /* Logo size when collapsed */
                .sidebar.collapsed .logo-circle {
                    width: 58px;
                    height: 58px;
                }

                /* Keep divider line */
                .sidebar.collapsed .logo-section {
                    padding: 25px 15px;
                    border-bottom: 1px solid rgba(255,255,255,.15);
                }

                /* Hide menu text only */
                .sidebar.collapsed .menu a span,
                .sidebar.collapsed .logout a span {
                    display: none;
                }

                /* Menu layout */
                .sidebar.collapsed .menu {
                    padding: 20px 12px;
                }

                    /* Menu items */
                    .sidebar.collapsed .menu a {
                        width: 50px;
                        height: 50px;
                        margin: 0 auto 18px auto;
                        padding: 0;
                        display: flex;
                        justify-content: center;
                        align-items: center;
                        border-radius: 8px;
                    }

                        /* Active menu */
                        .sidebar.collapsed .menu a.active {
                            background: #4a86ff;
                            box-shadow: 0 4px 10px rgba(0,0,0,.15);
                        }

                        .sidebar.collapsed .menu a i,
                        .sidebar.collapsed .logout a i {
                            margin: 0;
                            font-size: inherit;
                        }

                /* Logout */
                .sidebar.collapsed .logout {
                    margin-top: auto;
                    padding-bottom: 20px;
                }

                    .sidebar.collapsed .logout a {
                        width: 50px;
                        height: 50px;
                        margin: 0 auto;
                        padding: 0;
                        display: flex;
                        justify-content: center;
                        align-items: center;
                    }


         /* ================
               SETTINGS DROPDOWN
           ====================== */

        .sidebar-dropdown {
            margin-bottom: 10px;
        }

        .dropdown-toggle-menu {
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 14px;
            border-radius: 6px;
            cursor: pointer;
        }

            .dropdown-toggle-menu:hover {
                background: rgba(255,255,255,.12);
            }

        .small-arrow {
            font-size: 12px;
            transition: transform .3s ease;
        }

        /* submenu */
        .dropdown-submenu {
            display: none;
            flex-direction: column;
            padding-left: 20px;
        }

            .dropdown-submenu a {
                color: white;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 10px 12px;
                font-size: 14px;
                border-radius: 6px;
            }

                .dropdown-submenu a:hover {
                    background: rgba(255,255,255,.12);
                }

        /* active state */
        .sidebar-dropdown.open .dropdown-submenu {
            display: flex;
        }

        .sidebar-dropdown.open .small-arrow {
            transform: rotate(180deg);
        }

        /* Hide dropdown arrow when sidebar is collapsed */
        .sidebar.collapsed .small-arrow {
            display: none;
        }

        /* ==========================
                          LOGO DESIGN
                    ===========================*/
        .logo-section {
            text-align: center;
            padding: 25px 15px;
            border-bottom: 1px solid rgba(255, 255, 255, .15);
        }

        .logo-circle {
            width: 60px;
            height: 60px;
            background: white;
            border-radius: 50%;
            margin: auto;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .logo-img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

        .logout {
            margin-top: auto;
            padding: 15px 12px;
        }

            .logout a {
                color: white;
                text-decoration: none;
                display: flex;
                gap: 12px;
                align-items: center;
                padding: 12px 14px;
            }

        .system-name {
            margin-top: 12px;
            font-size: 14px;
            font-weight: 600;
        }
        /* ==========================
                 MENU DESIGN
           ===========================*/

        .menu {
            padding: 20px 12px;
        }

            .menu a {
                color: white;
                text-decoration: none;
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 14px;
                margin-bottom: 10px;
                border-radius: 6px;
            }

                .menu a:hover {
                    background: rgba(255,255,255,.12);
                }

                .menu a.active {
                    background: #3d7cff;
                    box-shadow: 0 4px 10px rgba(0,0,0,.15);
                }


        /* ==========================
           MAIN CONTENT
        ========================== */

        .main-content {
            flex: 1;
            background: #fafafa;
        }

        /* ==========================
                   TOP BAR
           ===========================*/
        .topbar {
            height: 60px;
            border-bottom: 1px solid #d9dce3;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 20px;
            background: #fff;
        }

        .menu-toggle {
            background: none;
            border: none;
            color: #243f99;
            font-size: 22px;
            cursor: pointer;
            margin-right: 10px;
        }

        .topbar-left {
            display: flex;
            align-items: center;
            gap: 18px;
            margin-right: 8px;
        }

            .topbar-left i {
                font-size: 28px;
                color: #243f99;
                cursor: pointer;
                margin: 8px;
            }

            .topbar-left h3 {
                color: #243f99;
                font-weight: 700;
                margin: 0;
            }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-left: auto;
        }

            .topbar-right i {
                font-size: 24px;
                cursor: pointer;
            }

        .profile {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .profile img {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                object-fit: cover;
            }

        .profile-info {
            display: flex;
            flex-direction: column;
            line-height: 1.2;
        }

            .profile-info .role {
                font-size: 12px;
                color: #777;
            }

            .profile-info h5 {
                margin: 0;
                font-size: 14px;
                font-weight: 600;
                color: #243f99;
            }

            .profile-info span {
                font-size: 12px;
                color: gray;
            }

        /* ==========================
           PAGE CONTENT
        ========================== */

        .page-content {
            padding: 25px;
        }

        /* ==========================
                   BREADCRUMB
           ========================== */
        .breadcrumb-title {
            font-size: 18px;
            font-weight: 700;
        }

        .records-breadcrumb {
            color: #9a9a9a;
            text-decoration: none;
        }

        .breadcrumb-title strong {
            color: #233f99;
        }

        .subtitle {
            margin-top: 5px;
            font-size: 14px;
            font-weight: 500;
        }

        /* ==========================
           STEPPER
        ========================== */

        .stepper {
            width: 80%;
            margin: 20px auto;
            display: flex;
            justify-content: center;
        }

        .step {
            flex: 1;
            text-align: center;
            position: relative;
        }

            .step:not(:last-child)::after {
                content: "";
                position: absolute;
                top: 14px;
                left: 60%;
                width: 80%;
                height: 1px;
                background: #cfcfcf;
            }

        .circle {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 1px solid #cfcfcf;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: auto;
            font-size: 13px;
            font-weight: 600;
        }

        .step.completed .circle,
        .step.active .circle {
            background: #356AE6;
            color: white;
            border: none;
        }

        .step small {
            display: block;
            margin-top: 8px;
            font-size: 12px;
            color: #808080;
        }

        .step.active small {
            color: #356AE6;
            font-weight: 600;
        }

        /* ==========================
           DETAILS CARD
        ========================== */

        .details-card {
            background: white;
            border: 1px solid #e4e7ee;
            border-radius: 8px;
            margin: 0 25px;
            padding: 18px;
        }

            .details-card h4 {
                font-size: 16px;
                font-weight: 700;
                margin-bottom: 5px;
            }

        .details-subtitle {
            color: #8d8d8d;
            font-size: 14px;
            margin-bottom: 20px;
        }

        .details-form {
            display: flex;
            gap: 25px;
            align-items: flex-start;
        }

        .left-section {
            flex: 1;
        }

        .right-section {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .details-card label {
            font-weight: 600;
            font-size: 14px;
            margin-bottom: 8px;
            display: block;
        }

        .form-control,
        .form-select {
            height: 46px;
            border: 1px solid #bfbfbf;
            border-radius: 6px;
        }

        textarea.form-control {
            height: 214px;
            resize: none;
            padding-top: 12px;
        }

        .description-wrapper {
            position: relative;
            flex: 1;
        }


        .description-box {
            width: 100%;
            height: 244px !important;
            resize: none;
            padding: 12px;
            padding-bottom: 35px;
        }

        .char-count {
            position: absolute;
            right: 12px;
            bottom: 12px;
            color: #808080;
            font-size: 14px;
            font-weight: 600;
            pointer-events: none;
        }

        .optional {
            color: #8c8c8c;
            font-size: 13px;
            font-weight: 500;
            margin-left: 4px;
        }

        .required {
            color: red;
        }

        /* Responsive */
        @@media(max-width:992px) {

            .details-form {
                flex-direction: column;
            }

            .left-section,
            .right-section {
                width: 100%;
            }
        }

        /* ==========================
                FOOTER BUTTONS
        ========================== */

        .footer-buttons {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            padding: 25px;
        }

        .btn-cancel,
        .btn-back {
            padding: 10px 28px;
            border: 1px solid #d5d5d5;
            border-radius: 4px;
            background: white;
            color: black;
            text-decoration: none;
            font-weight: 500;
        }

        .btn-next {
            padding: 10px 28px;
            border-radius: 4px;
            background: #356AE6;
            color: white;
            text-decoration: none;
            font-weight: 500;
        }

            .btn-next:hover {
                color: white;
                background: #2a58c8;
            }

        /* ==========================
                RESPONSIVE
        ========================== */

        @@media(max - width: 992px)

        {
            .details-card

        {
            margin: 0;
        }

        .stepper {
            width: 95%;
        }

        .footer-buttons {
            flex-wrap: wrap;
        }

        }

    </style>

</head>

<body>

    <div class="dashboard-container">

        <!-- SIDEBAR -->
        <aside class="sidebar">

            <div class="logo-section">

                <div class="logo-circle">
                    <img src="~/Images/logo.png" class="logo-img">
                </div>

                <div class="system-name">
                    SORS
                </div>

            </div>

            <div class="menu">

                <a href="@Url.Action("StaffDashboard", "Staff")">
                    <i class="bi bi-speedometer2"></i>
                    <span>Dashboard</span>
                </a>

                <a href="@Url.Action("RequestManagement", "Staff")">
                    <i class="bi bi-file-earmark-text"></i>
                    <span>Request</span>
                </a>

                <a href="@Url.Action("StaffRecordsManagement", "Staff")" class="active">
                    <i class="bi bi-folder2-open"></i>
                    <span>Records</span>
                </a>

                <a href="@Url.Action("ReportsManagement", "Staff")">
                    <i class="bi bi-clipboard-data"></i>
                    <span>Reports</span>
                </a>

                <!-- SETTINGS DROPDOWN -->
                <div class="sidebar-dropdown">

                    <a href="javascript:void(0)" class="dropdown-toggle-menu">
                        <i class="bi bi-gear"></i>
                        <span>Settings</span>
                        <i class="bi bi-caret-down-fill ms-auto small-arrow"></i>
                    </a>

                    <div class="dropdown-submenu">

                        <a href="@Url.Action("Settings", "Admin")">
                            <i class="bi bi-sliders"></i>
                            <span>General Settings</span>
                        </a>

                        <a href="@Url.Action("AccountAndSecurity", "Staff")">
                            <i class="bi bi-person-gear"></i>
                            <span>Account & Security</span>
                        </a>

                    </div>

                </div>

            </div>

            <div class="logout">

                <a href="@Url.Action("StaffLogin", "Staff")">
                    <i class="bi bi-box-arrow-right"></i>
                    <span>Logout</span>
                </a>

            </div>

        </aside>

        <!-- CONTENT -->
        <main class="main-content">

            <!-- TOP BAR -->
            <div class="topbar">

                <div class="topbar-left">
                    <button class="menu-toggle" id="menuToggle">
                        <i class="bi bi-list"></i>
                    </button>


                </div>

                <div class="topbar-right">

                    <i class="bi bi-bell-fill"></i>

                    <div class="profile">

                        <img src="~/Images/adminpic.jpg" alt="Profile" />

                        <div class="profile-info">
                            <span class="role">Staff</span>
                            <h5>John Doeh</h5>
                        </div>

                    </div>

                </div>
            </div>

            <div class="page-content">

                <div class="breadcrumb-title">

                    <a href="@Url.Action("StaffRecordsManagement", "Staff")"
                       class="records-breadcrumb">

                        Records

                    </a>

                    ›

                    <strong>Upload Records</strong>

                </div>

                <div class="subtitle">
                    Upload files to store and manage records securely.
                </div>
            </div>

            <!--STEPPER-->
            <div class="stepper">

                <div class="step completed">
                    <div class="circle">
                        <i class="bi bi-check-lg"></i>
                    </div>
                    <small>Upload Files</small>
                </div>

                <div class="step active">
                    <div class="circle">2</div>
                    <small>Add Details</small>
                </div>

                <div class="step">
                    <div class="circle">3</div>
                    <small>Review and Confirm</small>
                </div>

            </div>

            <div class="details-card">

                <h4>File Details</h4>

                <p class="details-subtitle">
                    Profile additional details / information.
                </p>

                <div class="details-form">

                    <!-- LEFT SIDE -->
                    <div class="left-section">

                        <label>
                            Full name <span class="required">*</span>
                        </label>

                        <input type="text"
                               class="form-control"
                               placeholder="Enter Full name" />

                        <label class="mt-4">
                            Category <span class="required">*</span>
                        </label>

                        <select class="form-select">
                            <option>Select category</option>
                            <option>Send-Off</option>
                            <option>Endorse(Emax & TP)</option>
                            <option>Endorse(Emax)</option>
                            <option>Endorse(TP)</option>
                        </select>

                        <label class="mt-4">
                            Date
                        </label>

                        <input type="date"
                               class="form-control" />

                    </div>

                    <!-- RIGHT SIDE -->
                    <div class="right-section">
                        <label>
                            Description

                            <span class="optional">(Optional)</span>
                        </label>

                        <div class="description-wrapper">

                            <textarea class="form-control description-box"
                                      maxlength="100"
                                      placeholder="Add description..."></textarea>

                            <span class="char-count">
                                0/100
                            </span>

                        </div>

                    </div>

                </div>

            </div>

            <!-- BUTTON FOOTERS-->
            <div class="footer-buttons">

                <a href="#" class="btn-cancel">
                    Cancel
                </a>

                <a href="@Url.Action("UploadFiles", "Staff")" class="btn-back">
                    Back
                </a>
                <a href="@Url.Action("UploadReviews", "Staff")" class="btn-next">
                    Next: Add Reviews
                    <i class="bi bi-arrow-right"></i>
                </a>

            </div>

        </main>

    </div>

    <script>
        const dropdown = document.querySelector('.sidebar-dropdown');
            const toggle = document.querySelector('.dropdown-toggle-menu');

        toggle.addEventListener('click', function () {
            dropdown.classList.toggle('open');
        });

        const sidebar = document.querySelector('.sidebar');
        const toggleBtn = document.getElementById('menuToggle');

        toggleBtn.addEventListener('click', function () {
            sidebar.classList.toggle('collapsed');
        });
    </script>


</body>
</html>